<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Project - Business Incubator Platform</title>
    <link href="/css/style.css" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-neo-white">
    <%- include('../partials/header.ejs') %>
    
    <main class="flex-1 px-4 py-12">
      <div class="w-full max-w-5xl mx-auto">
        <!-- Back Button -->
        <a
          href="/v1/projects"
          class="inline-flex items-center gap-2 mb-8 text-lg font-bold hover:-translate-x-2 transition-transform"
        >
          <span class="text-2xl">←</span> Back to Projects
        </a>

        <!-- Header Section -->
        <div class="mb-12 text-center">
          <div class="inline-block bg-brand-yellow px-6 py-2 border-2 border-neo-black rounded-full font-bold text-sm mb-4 shadow-neo transform -rotate-1">
            CREATE PROJECT
          </div>
          <h1 class="text-5xl md:text-6xl font-display font-bold text-neo-black mb-4">
            Share Your <span class="text-brand-blue">Innovation</span>
          </h1>
          <p class="text-xl text-gray-700 max-w-2xl mx-auto">
            Submit your project or startup idea to showcase it to our community.
          </p>
        </div>

        <!-- Form Section -->
        <form class="space-y-8">
          <!-- Error Message -->
          <div
            id="errorMessage"
            class="hidden bg-brand-pink/20 border-2 border-brand-pink rounded-2xl p-6 shadow-neo"
          >
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-pink border-2 border-neo-black rounded-full flex items-center justify-center text-2xl flex-shrink-0">
                ⚠️
              </div>
              <div>
                <h3 class="text-brand-pink font-bold text-xl mb-1">Error</h3>
                <p id="errorText" class="text-gray-800 font-medium"></p>
              </div>
            </div>
          </div>

          <!-- Success Message -->
          <div
            id="successMessage"
            class="hidden bg-green-100 border-2 border-green-500 rounded-2xl p-6 shadow-neo"
          >
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-green-500 border-2 border-neo-black rounded-full flex items-center justify-center text-2xl flex-shrink-0">
                ✅
              </div>
              <div>
                <h3 class="text-green-700 font-bold text-xl mb-1">Success!</h3>
                <p id="successText" class="text-gray-800 font-medium">
                  Your project has been submitted successfully!
                </p>
              </div>
            </div>
          </div>

          <!-- Section 1: Basic Information -->
          <div class="bg-white border-2 border-neo-black rounded-3xl p-8 md:p-10 shadow-neo">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-brand-yellow border-2 border-neo-black rounded-full flex items-center justify-center text-2xl font-bold shadow-neo">
                1
              </div>
              <h2 class="text-3xl font-display font-bold text-neo-black">
                Basic Information
              </h2>
            </div>

            <div class="space-y-6">
              <!-- Project Title -->
              <div>
                <label for="title" class="block text-lg font-bold text-neo-black mb-3">
                  Project Title <span class="text-brand-pink">*</span>
                </label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  placeholder="e.g., AI-Powered Learning Platform"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 transition-all"
                />
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  💡 Give your project a clear, catchy title.
                </p>
              </div>

              <!-- Short Description -->
              <div>
                <label for="shortDescription" class="block text-lg font-bold text-neo-black mb-3">
                  Short Description <span class="text-brand-pink">*</span>
                </label>
                <textarea
                  id="shortDescription"
                  name="shortDescription"
                  placeholder="Brief overview of your project in one or two sentences..."
                  rows="3"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  ✨ Keep it concise and engaging (max 150 characters)
                </p>
              </div>
            </div>
          </div>

          <!-- Section 2: Problem & Solution -->
          <div class="bg-white border-2 border-neo-black rounded-3xl p-8 md:p-10 shadow-neo">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-brand-blue text-white border-2 border-neo-black rounded-full flex items-center justify-center text-2xl font-bold shadow-neo">
                2
              </div>
              <h2 class="text-3xl font-display font-bold text-neo-black">
                Problem & Solution
              </h2>
            </div>

            <div class="space-y-6">
              <!-- Problem Statement -->
              <div>
                <label for="problem" class="block text-lg font-bold text-neo-black mb-3">
                  Problem This Project Solves <span class="text-brand-pink">*</span>
                </label>
                <textarea
                  id="problem"
                  name="problem"
                  placeholder="Describe the problem your project addresses. What pain point are you solving?"
                  rows="4"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-blue/50 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  🎯 Be specific about the problem and its impact
                </p>
              </div>

              <!-- Solution Description -->
              <div>
                <label for="solution" class="block text-lg font-bold text-neo-black mb-3">
                  How Your Project Solves It <span class="text-brand-pink">*</span>
                </label>
                <textarea
                  id="solution"
                  name="solution"
                  placeholder="Explain your approach and how it addresses the problem..."
                  rows="4"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-blue/50 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  💡 Highlight key features and unique aspects of your solution
                </p>
              </div>
            </div>
          </div>

          <!-- Section 3: Technical Details -->
          <div class="bg-white border-2 border-neo-black rounded-3xl p-8 md:p-10 shadow-neo">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-brand-pink text-white border-2 border-neo-black rounded-full flex items-center justify-center text-2xl font-bold shadow-neo">
                3
              </div>
              <h2 class="text-3xl font-display font-bold text-neo-black">
                Technical Details
              </h2>
            </div>

            <div class="space-y-6">
              <!-- Tech Stack -->
              <div>
                <label for="techStack" class="block text-lg font-bold text-neo-black mb-3">
                  Tech Stack / Tools Used <span class="text-brand-pink">*</span>
                </label>
                <input
                  type="text"
                  id="techStack"
                  name="techStack"
                  placeholder="e.g., React, Node.js, MongoDB, Python, TensorFlow, AWS"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-pink/50 transition-all"
                />
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  🛠️ Separate technologies with commas
                </p>
              </div>

              <!-- Project Status -->
              <div>
                <label for="status" class="block text-lg font-bold text-neo-black mb-3">
                  Project Status <span class="text-brand-pink">*</span>
                </label>
                <select
                  id="status"
                  name="status"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-pink/50 transition-all"
                >
                  <option value="">Select a status...</option>
                  <option value="idea">💡 Idea (Concept only)</option>
                  <option value="in-progress">🔨 In Progress (Active development)</option>
                  <option value="completed">🚀 Completed (MVP or full launch)</option>
                </select>
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  📊 Choose the current stage of your project
                </p>
              </div>

              <!-- Detailed Description -->
              <div>
                <label for="fullDescription" class="block text-lg font-bold text-neo-black mb-3">
                  Detailed Description
                </label>
                <textarea
                  id="fullDescription"
                  name="fullDescription"
                  placeholder="Provide a comprehensive overview. Include features, timeline, target market, etc..."
                  rows="5"
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-pink/50 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-sm mt-2 font-medium">
                  📝 Optional but recommended for better understanding
                </p>
              </div>
            </div>
          </div>

          <!-- Section 4: Links & Resources -->
          <div class="bg-white border-2 border-neo-black rounded-3xl p-8 md:p-10 shadow-neo">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-brand-yellow border-2 border-neo-black rounded-full flex items-center justify-center text-2xl font-bold shadow-neo">
                4
              </div>
              <h2 class="text-3xl font-display font-bold text-neo-black">
                Links & Resources
              </h2>
            </div>

            <div class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- GitHub Link -->
                <div>
                  <label for="github" class="block text-lg font-bold text-neo-black mb-3">
                    GitHub Repository
                  </label>
                  <input
                    type="url"
                    id="github"
                    name="github"
                    placeholder="https://github.com/username/project"
                    class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 transition-all"
                  />
                </div>

                <!-- Demo Link -->
                <div>
                  <label for="demo" class="block text-lg font-bold text-neo-black mb-3">
                    Live Demo
                  </label>
                  <input
                    type="url"
                    id="demo"
                    name="demo"
                    placeholder="https://project-demo.com"
                    class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 transition-all"
                  />
                </div>
              </div>

              <!-- Website Link -->
              <div>
                <label for="website" class="block text-lg font-bold text-neo-black mb-3">
                  Project Website / Landing Page
                </label>
                <input
                  type="url"
                  id="website"
                  name="website"
                  placeholder="https://project-website.com"
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 transition-all"
                />
              </div>

              <!-- Other Links -->
              <div>
                <label for="otherLinks" class="block text-lg font-bold text-neo-black mb-3">
                  Other Links
                </label>
                <textarea
                  id="otherLinks"
                  name="otherLinks"
                  placeholder="LinkedIn, Twitter, Pitch Deck, Drive Folder, etc. (One link per line)"
                  rows="3"
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 transition-all resize-none"
                ></textarea>
              </div>
            </div>
          </div>

          <!-- Section 5: Team Information -->
          <div class="bg-white border-2 border-neo-black rounded-3xl p-8 md:p-10 shadow-neo">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-brand-blue text-white border-2 border-neo-black rounded-full flex items-center justify-center text-2xl font-bold shadow-neo">
                5
              </div>
              <h2 class="text-3xl font-display font-bold text-neo-black">
                Team Information
              </h2>
            </div>

            <div class="space-y-6">
              <!-- Team Type -->
              <div>
                <label for="teamType" class="block text-lg font-bold text-neo-black mb-3">
                  Team Type <span class="text-brand-pink">*</span>
                </label>
                <select
                  id="teamType"
                  name="teamType"
                  required
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-blue/50 transition-all"
                >
                  <option value="">Select team structure...</option>
                  <option value="individual">👤 Individual Founder</option>
                  <option value="team">👥 Team (2-3 members)</option>
                  <option value="large-team">👨‍👩‍👧‍👦 Large Team (4+ members)</option>
                </select>
              </div>

              <!-- Team Members -->
              <div>
                <label for="teamMembers" class="block text-lg font-bold text-neo-black mb-3">
                  Team Members / Founders
                </label>
                <textarea
                  id="teamMembers"
                  name="teamMembers"
                  placeholder="List team members and their roles. Format: Name - Role (One per line)
e.g:
John Doe - Lead Developer
Jane Smith - Product Manager"
                  rows="4"
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-blue/50 transition-all resize-none"
                ></textarea>
              </div>

              <!-- Looking for Co-founders -->
              <div class="bg-brand-yellow/20 border-2 border-neo-black rounded-2xl p-6">
                <div class="flex items-start gap-4">
                  <input
                    type="checkbox"
                    id="lookingForCoFounders"
                    name="lookingForCoFounders"
                    class="w-6 h-6 bg-white border-2 border-neo-black rounded text-brand-blue focus:outline-none focus:ring-4 focus:ring-brand-yellow/50 mt-1"
                  />
                  <label for="lookingForCoFounders" class="text-lg font-bold text-neo-black">
                    🔍 We are looking for co-founders / team members
                  </label>
                </div>
              </div>

              <!-- Needed Skills -->
              <div>
                <label for="neededSkills" class="block text-lg font-bold text-neo-black mb-3">
                  Needed Skills / Expertise
                </label>
                <input
                  type="text"
                  id="neededSkills"
                  name="neededSkills"
                  placeholder="e.g., Product Manager, Full-Stack Developer, AI/ML Expert"
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-blue/50 transition-all"
                />
              </div>
            </div>
          </div>

          <!-- Section 6: Additional Information -->
          <div class="bg-white border-2 border-neo-black rounded-3xl p-8 md:p-10 shadow-neo">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-brand-pink text-white border-2 border-neo-black rounded-full flex items-center justify-center text-2xl font-bold shadow-neo">
                6
              </div>
              <h2 class="text-3xl font-display font-bold text-neo-black">
                Additional Information
              </h2>
            </div>

            <div class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Funding Stage -->
                <div>
                  <label for="fundingStage" class="block text-lg font-bold text-neo-black mb-3">
                    Funding Stage
                  </label>
                  <select
                    id="fundingStage"
                    name="fundingStage"
                    class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-pink/50 transition-all"
                  >
                    <option value="">Select funding stage...</option>
                    <option value="pre-seed">💡 Pre-Seed (Ideation)</option>
                    <option value="seed">🌱 Seed Round</option>
                    <option value="series-a">📈 Series A</option>
                    <option value="bootstrapped">💪 Bootstrapped</option>
                    <option value="not-seeking">🚫 Not seeking funding</option>
                  </select>
                </div>

                <!-- Target Market -->
                <div>
                  <label for="targetMarket" class="block text-lg font-bold text-neo-black mb-3">
                    Target Market / Industry
                  </label>
                  <input
                    type="text"
                    id="targetMarket"
                    name="targetMarket"
                    placeholder="e.g., EdTech, FinTech, Healthcare"
                    class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-pink/50 transition-all"
                  />
                </div>
              </div>

              <!-- Additional Notes -->
              <div>
                <label for="additionalNotes" class="block text-lg font-bold text-neo-black mb-3">
                  Additional Notes
                </label>
                <textarea
                  id="additionalNotes"
                  name="additionalNotes"
                  placeholder="Any other information you'd like to share about the project..."
                  rows="3"
                  class="w-full bg-white border-2 border-neo-black rounded-xl px-6 py-4 text-lg font-medium focus:outline-none focus:ring-4 focus:ring-brand-pink/50 transition-all resize-none"
                ></textarea>
              </div>

              <!-- Agree to Terms -->
              <div class="bg-neo-white border-2 border-neo-black rounded-2xl p-6">
                <div class="flex items-start gap-4">
                  <input
                    type="checkbox"
                    id="agreeTerms"
                    name="agreeTerms"
                    required
                    class="w-6 h-6 bg-white border-2 border-neo-black rounded text-brand-blue focus:outline-none focus:ring-4 focus:ring-brand-pink/50 mt-1"
                  />
                  <label for="agreeTerms" class="text-base font-medium text-gray-800">
                    ✅ I confirm that this project information is accurate and that I have the rights to share this content.
                    <span class="text-brand-pink font-bold">*</span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit & Cancel Buttons -->
          <div class="flex flex-col md:flex-row gap-4 justify-end">
            <a
              href="/projects"
              class="px-8 py-4 bg-white text-neo-black text-lg font-bold rounded-full border-2 border-neo-black shadow-neo hover:-translate-y-1 transition-transform text-center"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-8 py-4 bg-brand-blue text-white text-lg font-bold rounded-full border-2 border-neo-black shadow-neo hover:-translate-y-1 transition-transform"
            >
              Publish Project 🚀
            </button>
          </div>
        </form>
      </div>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script src="/js/add-project.js"></script>
  </body>
</html>