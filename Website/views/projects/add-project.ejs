<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Project - Business Incubator Platform</title>
    <link href="/css/style.css" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <%- include('../partials/header.ejs') %>
    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <div class="w-full max-w-4xl">
        <!-- Back Button -->
        <a
          href="/v1/projects"
          class="text-gray-600 hover:text-gray-900 flex items-center gap-2 mb-8 transition-colors"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"
            />
          </svg>
          Back to Projects
        </a>

        <!-- Header Section -->
        <div class="mb-10">
          <span class="text-sm uppercase tracking-widest text-gray-600"
            >Create Project</span
          >
          <h1 class="text-4xl md:text-5xl font-bold mt-3 text-gray-900">
            Share Your Innovation
          </h1>
          <p class="text-gray-700 mt-3 max-w-2xl">
            Submit your project or startup idea to showcase it to our community.
            Fill in all the details to help others understand your vision.
          </p>
        </div>

        <!-- Form Section -->
        <form
          class="bg-gray-50 border border-gray-200 rounded-2xl p-8 shadow-xl space-y-8"
        >
          <!-- Error Message -->
          <div
            id="errorMessage"
            class="hidden bg-red-50 border border-red-200 rounded-2xl p-4 flex items-start gap-3"
          >
            <svg
              class="w-6 h-6 text-red-500 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <div>
              <h3 class="text-red-700 font-semibold mb-1">Error</h3>
              <p id="errorText" class="text-red-600 text-sm"></p>
            </div>
          </div>

          <!-- Success Message -->
          <div
            id="successMessage"
            class="hidden bg-green-50 border border-green-200 rounded-2xl p-4 flex items-start gap-3"
          >
            <svg
              class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <div>
              <h3 class="text-green-700 font-semibold mb-1">Success</h3>
              <p id="successText" class="text-green-600 text-sm">
                Your project has been submitted successfully!
              </p>
            </div>
          </div>

          <!-- Section 1: Basic Information -->
          <div class="border-b border-gray-200 pb-8">
            <h2
              class="text-2xl font-bold mb-6 flex items-center gap-3 text-gray-900"
            >
              <span
                class="bg-blue-600 w-8 h-8 rounded-full flex items-center justify-center text-sm text-white"
                >1</span
              >
              Basic Information
            </h2>

            <div class="space-y-5">
              <!-- Project Title -->
              <div>
                <label
                  for="title"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Project Title <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  placeholder="e.g., AI-Powered Learning Platform"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
                <p class="text-gray-600 text-xs mt-1">
                  Give your project a clear, catchy title.
                </p>
              </div>

              <!-- Short Description -->
              <div>
                <label
                  for="shortDescription"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Short Description <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="shortDescription"
                  name="shortDescription"
                  placeholder="Brief overview of your project in one or two sentences..."
                  rows="2"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-xs mt-1">
                  Keep it concise and engaging (max 150 characters)
                </p>
              </div>
            </div>
          </div>
          <!-- Section 2: Problem & Solution -->
          <div class="border-b border-gray-200 pb-8">
            <h2
              class="text-2xl font-bold mb-6 flex items-center gap-3 text-gray-900"
            >
              <span
                class="bg-blue-600 w-8 h-8 rounded-full flex items-center justify-center text-sm text-white"
                >2</span
              >
              Problem & Solution
            </h2>

            <div class="space-y-5">
              <!-- Problem Statement -->
              <div>
                <label
                  for="problem"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Problem This Project Solves
                  <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="problem"
                  name="problem"
                  placeholder="Describe the problem your project addresses. What pain point are you solving?"
                  rows="4"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-xs mt-1">
                  Be specific about the problem and its impact
                </p>
              </div>

              <!-- Solution Description -->
              <div>
                <label
                  for="solution"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  How Your Project Solves It <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="solution"
                  name="solution"
                  placeholder="Explain your approach and how it addresses the problem..."
                  rows="4"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-xs mt-1">
                  Highlight key features and unique aspects of your solution
                </p>
              </div>
            </div>
          </div>

          <!-- Section 3: Technical Details -->
          <div class="border-b border-gray-200 pb-8">
            <h2
              class="text-2xl font-bold mb-6 flex items-center gap-3 text-gray-900"
            >
              <span
                class="bg-blue-600 w-8 h-8 rounded-full flex items-center justify-center text-sm text-white"
                >3</span
              >
              Technical Details
            </h2>

            <div class="space-y-5">
              <!-- Tech Stack -->
              <div>
                <label
                  for="techStack"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Tech Stack / Tools Used <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="techStack"
                  name="techStack"
                  placeholder="e.g., React, Node.js, MongoDB, Python, TensorFlow, AWS"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
                <p class="text-gray-600 text-xs mt-1">
                  Separate technologies with commas. This helps with
                  discoverability.
                </p>
              </div>

              <!-- Project Status -->
              <div>
                <label
                  for="status"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Project Status <span class="text-red-500">*</span>
                </label>
                <select
                  id="status"
                  name="status"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                >
                  <option value="">Select a status...</option>
                  <option value="idea">Idea (Concept only)</option>
                  <option value="in-progress">
                    In Progress (Active development)
                  </option>
                  <option value="completed">
                    Completed (MVP or full launch)
                  </option>
                </select>
                <p class="text-gray-600 text-xs mt-1">
                  Choose the current stage of your project
                </p>
              </div>

              <!-- Detailed Description -->
              <div>
                <label
                  for="fullDescription"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Detailed Description
                </label>
                <textarea
                  id="fullDescription"
                  name="fullDescription"
                  placeholder="Provide a comprehensive overview. Include features, timeline, target market, etc..."
                  rows="5"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
                <p class="text-gray-600 text-xs mt-1">
                  Optional but recommended for better project understanding
                </p>
              </div>
            </div>
          </div>

          <!-- Section 4: Links & Resources -->
          <div class="border-b border-gray-200 pb-8">
            <h2
              class="text-2xl font-bold mb-6 flex items-center gap-3 text-gray-900"
            >
              <span
                class="bg-blue-600 w-8 h-8 rounded-full flex items-center justify-center text-sm text-white"
                >4</span
              >
              Links & Resources
            </h2>

            <div class="space-y-5">
              <!-- GitHub Link -->
              <div>
                <label
                  for="github"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  GitHub Repository
                </label>
                <input
                  type="url"
                  id="github"
                  name="github"
                  placeholder="https://github.com/username/project"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
                <p class="text-gray-600 text-xs mt-1">
                  Link to your GitHub repository (if available)
                </p>
              </div>

              <!-- Demo Link -->
              <div>
                <label
                  for="demo"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Live Demo / Website
                </label>
                <input
                  type="url"
                  id="demo"
                  name="demo"
                  placeholder="https://project-demo.com"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
                <p class="text-gray-600 text-xs mt-1">
                  Link to your live demo or website
                </p>
              </div>

              <!-- Website/Portfolio Link -->
              <div>
                <label
                  for="website"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Project Website / Landing Page
                </label>
                <input
                  type="url"
                  id="website"
                  name="website"
                  placeholder="https://project-website.com"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
                <p class="text-gray-600 text-xs mt-1">
                  Link to your project's dedicated website
                </p>
              </div>

              <!-- Other Links -->
              <div>
                <label
                  for="otherLinks"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Other Links
                </label>
                <textarea
                  id="otherLinks"
                  name="otherLinks"
                  placeholder="LinkedIn, Twitter, Pitch Deck, Drive Folder, etc. (One link per line)"
                  rows="3"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
              </div>
            </div>
          </div>

          <!-- Section 5: Team Information -->
          <div class="border-b border-gray-200 pb-8">
            <h2
              class="text-2xl font-bold mb-6 flex items-center gap-3 text-gray-900"
            >
              <span
                class="bg-blue-600 w-8 h-8 rounded-full flex items-center justify-center text-sm text-white"
                >5</span
              >
              Team Information
            </h2>

            <div class="space-y-5">
              <!-- Team Type -->
              <div>
                <label
                  for="teamType"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Team Type <span class="text-red-500">*</span>
                </label>
                <select
                  id="teamType"
                  name="teamType"
                  required
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                >
                  <option value="">Select team structure...</option>
                  <option value="individual">Individual Founder</option>
                  <option value="team">Team (2-3 members)</option>
                  <option value="large-team">Large Team (4+ members)</option>
                </select>
              </div>

              <!-- Team Members -->
              <div>
                <label
                  for="teamMembers"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Team Members / Founders
                </label>
                <textarea
                  id="teamMembers"
                  name="teamMembers"
                  placeholder="List team members and their roles. Format: Name - Role (One per line)
                  e.g:
                  John Doe - Lead Developer
                  Jane Smith - Product Manager
                  Mike Johnson - Designer"
                  rows="4"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
              </div>

              <!-- Looking for Co-founders -->
              <div class="flex items-center gap-3">
                <input
                  type="checkbox"
                  id="lookingForCoFounders"
                  name="lookingForCoFounders"
                  class="w-4 h-4 bg-white border border-gray-300 rounded text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
                />
                <label
                  for="lookingForCoFounders"
                  class="text-sm font-medium text-gray-900"
                >
                  We are looking for co-founders / team members
                </label>
              </div>

              <!-- Needed Skills -->
              <div>
                <label
                  for="neededSkills"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Needed Skills / Expertise (if looking for team members)
                </label>
                <input
                  type="text"
                  id="neededSkills"
                  name="neededSkills"
                  placeholder="e.g., Product Manager, Full-Stack Developer, AI/ML Expert"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
              </div>
            </div>
          </div>

          <!-- Section 6: Additional Information -->
          <div class="pb-8">
            <h2
              class="text-2xl font-bold mb-6 flex items-center gap-3 text-gray-900"
            >
              <span
                class="bg-blue-600 w-8 h-8 rounded-full flex items-center justify-center text-sm text-white"
                >6</span
              >
              Additional Information
            </h2>

            <div class="space-y-5">
              <!-- Funding Stage -->
              <div>
                <label
                  for="fundingStage"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Funding Stage
                </label>
                <select
                  id="fundingStage"
                  name="fundingStage"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                >
                  <option value="">Select funding stage...</option>
                  <option value="pre-seed">Pre-Seed (Ideation)</option>
                  <option value="seed">Seed Round</option>
                  <option value="series-a">Series A</option>
                  <option value="bootstrapped">Bootstrapped</option>
                  <option value="not-seeking">
                    Not actively seeking funding
                  </option>
                </select>
              </div>

              <!-- Target Market -->
              <div>
                <label
                  for="targetMarket"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Target Market / Industry
                </label>
                <input
                  type="text"
                  id="targetMarket"
                  name="targetMarket"
                  placeholder="e.g., EdTech, FinTech, Healthcare, E-commerce"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                />
              </div>

              <!-- Additional Notes -->
              <div>
                <label
                  for="additionalNotes"
                  class="block text-sm font-semibold text-gray-900 mb-2"
                >
                  Additional Notes
                </label>
                <textarea
                  id="additionalNotes"
                  name="additionalNotes"
                  placeholder="Any other information you'd like to share about the project..."
                  rows="3"
                  class="w-full bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                ></textarea>
              </div>

              <!-- Agree to Terms -->
              <div class="flex items-start gap-3 pt-4">
                <input
                  type="checkbox"
                  id="agreeTerms"
                  name="agreeTerms"
                  required
                  class="w-4 h-4 bg-white border border-gray-300 rounded text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500/20 mt-1"
                />
                <label for="agreeTerms" class="text-sm text-gray-700">
                  I confirm that this project information is accurate and that I
                  have the rights to share this content.
                  <span class="text-red-500">*</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Submit & Cancel Buttons -->
          <div class="flex gap-4 justify-end pt-6 border-t border-gray-200">
            <a
              href="/projects"
              class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-900 rounded-lg font-semibold transition-colors"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-8 py-3 bg-blue-600 hover:bg-blue-700 rounded-lg font-semibold transition-colors text-white"
            >
              Publish Project
            </button>
          </div>
        </form>
      </div>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script>
      // Form submission handler
      document.querySelector("form").addEventListener("submit", function (e) {
        e.preventDefault();

        // Validate required fields
        const title = document.getElementById("title").value.trim();
        const shortDescription = document
          .getElementById("shortDescription")
          .value.trim();
        const problem = document.getElementById("problem").value.trim();
        const solution = document.getElementById("solution").value.trim();
        const techStack = document.getElementById("techStack").value.trim();
        const status = document.getElementById("status").value;
        const teamType = document.getElementById("teamType").value;
        const agreeTerms = document.getElementById("agreeTerms").checked;

        if (
          !title ||
          !shortDescription ||
          !problem ||
          !solution ||
          !techStack ||
          !status ||
          !teamType ||
          !agreeTerms
        ) {
          showError(
            "Please fill in all required fields and agree to the terms.",
          );
          return;
        }

        // Show success message
        showSuccess("Project published successfully!");

        // Reset form after 1.5 seconds
        setTimeout(() => {
          // window.location.href = '/projects';
          this.reset();
        }, 1500);
      });

      function showError(message) {
        const errorDiv = document.getElementById("errorMessage");
        document.getElementById("errorText").textContent = message;
        errorDiv.classList.remove("hidden");
        document.getElementById("successMessage").classList.add("hidden");
      }

      function showSuccess(message) {
        const successDiv = document.getElementById("successMessage");
        document.getElementById("successText").textContent = message;
        successDiv.classList.remove("hidden");
        document.getElementById("errorMessage").classList.add("hidden");
      }
    </script>
  </body>
</html>
