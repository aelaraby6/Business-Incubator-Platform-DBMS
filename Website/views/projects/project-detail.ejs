<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= project.title %> - Business Incubator Platform
  </title>
  <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-white text-gray-900 min-h-screen flex flex-col">
  <%- include('../partials/header.ejs') %>

    <section class="min-h-screen bg-neo-white py-12 px-4 border-t-2 border-neo-black">
      <div class="max-w-7xl mx-auto">
        <!-- Back Button -->
        <a href="<%= routes.projects %>"
          class="inline-flex items-center gap-2 mb-8 text-lg font-bold hover:-translate-x-2 transition-transform">
          <span class="text-2xl">←</span> Back to Projects
        </a>

        <!-- Project Header -->
        <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-8 md:p-12 mb-8">
          <div class="flex flex-col md:flex-row justify-between items-start gap-6 mb-6">
            <div class="flex-1">
              <h1 class="text-5xl md:text-6xl font-display font-bold text-neo-black mb-4">
                <%= project.title %>
              </h1>
              <p class="text-xl text-gray-700 leading-relaxed">
                <%= project.description %>
              </p>
            </div>

            <div class="flex flex-col gap-3">
              <span
                class="bg-brand-yellow px-6 py-3 text-lg font-bold border-2 border-neo-black rounded-full shadow-neo text-center whitespace-nowrap">
                <%= project.status %>
              </span>
            </div>
          </div>

          <!-- Quick Stats -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
            <div class="bg-brand-pink/20 border-2 border-neo-black rounded-2xl p-6 text-center">
              <div class="text-4xl font-bold font-display text-brand-pink mb-2">
                <%= project.team.length %>
              </div>
              <div class="text-sm font-bold uppercase tracking-wide">Team Members</div>
            </div>

            <div class="bg-brand-blue/20 border-2 border-neo-black rounded-2xl p-6 text-center">
              <div class="text-2xl font-bold text-brand-blue mb-2">
                <%= project.techStack[0] %>
              </div>
              <div class="text-sm font-bold uppercase tracking-wide">Main Framework</div>
            </div>

            <div class="bg-brand-yellow/30 border-2 border-neo-black rounded-2xl p-6 text-center">
              <div class="text-2xl font-bold text-neo-black mb-2">
                <%= project.targetMarket.split(',')[0] %>
              </div>
              <div class="text-sm font-bold uppercase tracking-wide">Industry</div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Main Content -->
          <div class="lg:col-span-2 space-y-8">
            <!-- Problem & Solution -->
            <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-8 md:p-10">
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-12 h-12 bg-brand-pink rounded-full border-2 border-neo-black flex items-center justify-center text-2xl">
                  🎯
                </div>
                <h2 class="text-3xl font-display font-bold">Problem Being Solved</h2>
              </div>
              <p class="text-lg text-gray-800 leading-relaxed">
                <%= project.problem %>
              </p>
            </div>

            <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-8 md:p-10">
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-12 h-12 bg-brand-blue rounded-full border-2 border-neo-black flex items-center justify-center text-2xl">
                  💡
                </div>
                <h2 class="text-3xl font-display font-bold">Our Solution</h2>
              </div>
              <p class="text-lg text-gray-800 leading-relaxed">
                <%= project.solution %>
              </p>
            </div>

            <!-- Technology Stack -->
            <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-8 md:p-10">
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-12 h-12 bg-brand-yellow rounded-full border-2 border-neo-black flex items-center justify-center text-2xl">
                  🛠️
                </div>
                <h2 class="text-3xl font-display font-bold">Technology Stack</h2>
              </div>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                <% project.techStack.forEach((tech, index)=> { %>
                  <div
                    class="bg-neo-white border-2 border-neo-black rounded-xl p-4 hover:-translate-y-1 transition-transform">
                    <div class="text-sm font-bold text-gray-500 mb-1">Tech <%= index + 1 %>
                    </div>
                    <div class="font-bold text-lg">
                      <%= tech %>
                    </div>
                  </div>
                  <% }); %>
              </div>
            </div>

            <!-- Team -->
            <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-8 md:p-10">
              <div class="flex items-center gap-3 mb-8">
                <div
                  class="w-12 h-12 bg-brand-pink rounded-full border-2 border-neo-black flex items-center justify-center text-2xl">
                  👥
                </div>
                <h2 class="text-3xl font-display font-bold">Team</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% project.team.forEach(member=> { %>
                  <div
                    class="flex items-center gap-4 bg-neo-white border-2 border-neo-black rounded-2xl p-6 hover:shadow-neo transition-shadow">
                    <div
                      class="w-16 h-16 bg-brand-blue text-white border-2 border-neo-black rounded-full flex items-center justify-center font-bold text-xl flex-shrink-0">
                      <%= member.initials %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-bold text-lg truncate">
                        <%= member.name %>
                      </h3>
                      <p class="text-gray-600 truncate">
                        <%= member.role %>
                      </p>
                    </div>
                  </div>
                  <% }); %>
              </div>

              <button
                class="w-full mt-6 bg-brand-blue text-white text-lg font-bold py-4 px-8 rounded-full border-2 border-neo-black shadow-neo hover:-translate-y-1 transition-transform">
                Connect with Team 💬
              </button>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-1">
            <div class="space-y-6 lg:sticky lg:top-6">
              <!-- Project Details -->
              <div class="bg-neo-black text-white border-2 border-neo-black rounded-3xl shadow-neo p-8">
                <h2 class="text-2xl font-display font-bold mb-6">Project Details</h2>

                <div class="space-y-6">
                  <div>
                    <div class="text-sm font-bold text-gray-400 mb-2">Funding Stage</div>
                    <div class="text-lg font-bold">
                      <%= project.fundingStage %>
                    </div>
                  </div>

                  <div class="border-t border-gray-700 pt-6">
                    <div class="text-sm font-bold text-gray-400 mb-2">Target Market</div>
                    <div class="text-lg font-bold">
                      <%= project.targetMarket %>
                    </div>
                  </div>

                  <div class="border-t border-gray-700 pt-6">
                    <div class="text-sm font-bold text-gray-400 mb-2">Project Started</div>
                    <div class="text-lg font-bold">
                      <%= project.startDate %>
                    </div>
                  </div>

                  <div class="border-t border-gray-700 pt-6">
                    <div class="text-sm font-bold text-gray-400 mb-2">Looking for Co-founders</div>
                    <% if (project.lookingForCoFounders) { %>
                      <div
                        class="bg-brand-yellow text-neo-black px-4 py-2 rounded-full border-2 border-white font-bold inline-block">
                        Yes ✅
                      </div>
                      <div class="mt-3 text-sm">
                        <%= project.neededRoles %>
                      </div>
                      <% } else { %>
                        <div class="text-lg font-bold text-gray-400">No</div>
                        <% } %>
                  </div>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-6 space-y-4">
                <button
                  class="w-full bg-brand-yellow text-neo-black text-lg font-bold py-4 px-6 rounded-full border-2 border-neo-black shadow-neo hover:-translate-y-1 transition-transform">
                  View Demo 🚀
                </button>

                <button
                  class="w-full bg-white text-neo-black text-lg font-bold py-4 px-6 rounded-full border-2 border-neo-black shadow-neo hover:-translate-y-1 transition-transform">
                  Visit GitHub 💻
                </button>

                <button
                  class="w-full bg-brand-pink text-white text-lg font-bold py-4 px-6 rounded-full border-2 border-neo-black shadow-neo hover:-translate-y-1 transition-transform">
                  Share Project 📤
                </button>
              </div>

              <!-- Resources -->
              <div class="bg-white border-2 border-neo-black rounded-3xl shadow-neo p-6">
                <h3 class="text-xl font-display font-bold mb-4">Resources</h3>
                <div class="space-y-3">
                  <a href="#"
                    class="flex items-center gap-3 p-3 bg-neo-white border-2 border-neo-black rounded-xl hover:shadow-neo transition-shadow">
                    <span class="text-2xl">📦</span>
                    <span class="font-bold">GitHub Repository</span>
                  </a>
                  <a href="#"
                    class="flex items-center gap-3 p-3 bg-neo-white border-2 border-neo-black rounded-xl hover:shadow-neo transition-shadow">
                    <span class="text-2xl">🌐</span>
                    <span class="font-bold">Live Demo</span>
                  </a>
                  <a href="#"
                    class="flex items-center gap-3 p-3 bg-neo-white border-2 border-neo-black rounded-xl hover:shadow-neo transition-shadow">
                    <span class="text-2xl">🔗</span>
                    <span class="font-bold">Project Website</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <%- include('../partials/footer.ejs') %>
      <script src="/js/project-details.js"></script>
</body>

</html>