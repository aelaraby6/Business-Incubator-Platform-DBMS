<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Projects & Ideas | Business Incubator</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Space+Grotesk:wght@300..700&display=swap"
    rel="stylesheet" />

  <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-[#FFFDF5] flex flex-col min-h-screen">
  <%- include('../partials/header.ejs') %>

    <main class="flex-grow">

      <!-- Hero Section -->
      <div class="container mx-auto px-4 py-16 text-center">
        <span
          class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-4 inline-block transform -rotate-2">
          Innovation Hub
        </span>
        <h1 class="text-6xl md:text-7xl font-bold text-black mb-6">
          PROJECTS & <span class="bg-[#78FFD6] text-black px-2 border-4 border-black shadow-neo italic">IDEAS</span>
        </h1>
        <p class="text-xl text-gray-700 max-w-2xl mx-auto font-medium">
          Explore innovative projects and startup ideas from our incubator community.
        </p>
      </div>

      <!-- Marquee Banner -->
      <div class="bg-[#5465FF] border-y-4 border-black py-3 mb-16 marquee-container">
        <div class="marquee-content text-xl font-bold uppercase tracking-wider text-white">
          Build • Collaborate • Innovate • Ship • Iterate • Scale • Create • Launch • Grow • Succeed •
          Build • Collaborate • Innovate • Ship • Iterate • Scale • Create • Launch • Grow • Succeed •
        </div>
      </div>

      <!-- Search & Filter Section -->
      <div class="container mx-auto px-4 mb-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto">
          <input type="text" id="searchInput" placeholder="Search projects..."
            class="col-span-1 md:col-span-2 bg-white border-4 border-black rounded-none px-4 py-3 text-black placeholder-gray-500 focus:outline-none font-bold shadow-[4px_4px_0_0_#000]" />
          <select id="statusFilter"
            class="bg-white border-4 border-black rounded-none px-4 py-3 text-black focus:outline-none font-bold shadow-[4px_4px_0_0_#000]">
            <option value="">All Status</option>
            <option value="idea">Idea</option>
            <option value="in-progress">In Progress</option>
            <option value="completed">Completed</option>
          </select>
        </div>
      </div>

      <!-- Projects Grid -->
      <div class="container mx-auto px-4 mb-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" id="projectsGrid">

          <% projects.forEach(project=> {
            let headerColor = '#5465FF';
            let iconClass = 'fa-lightbulb';

            if (project.status.toLowerCase() === 'in-progress' || project.status.toLowerCase() === 'in progress') {
            headerColor = '#FFDE59';
            iconClass = 'fa-rocket';
            } else if (project.status.toLowerCase() === 'completed') {
            headerColor = '#78FFD6';
            iconClass = 'fa-trophy';
            }
            %>

            <!-- Project Card -->
            <div
              class="bg-white border-4 border-black rounded-xl overflow-hidden shadow-neo flex flex-col h-full transform transition hover:-translate-y-2 duration-300 group project-card"
              data-status="<%= project.status.toLowerCase() %>" data-title="<%= project.title.toLowerCase() %>"
              data-description="<%= project.description.toLowerCase() %>"
              data-tech="<%= project.techStack.join(' ').toLowerCase() %>">

              <!-- Header with Color Band -->
              <div class="h-32 border-b-4 border-black relative"
                style="background-color: <%= headerColor %>; background-image: radial-gradient(black 1px, transparent 1px); background-size: 10px 10px; opacity: 0.9;">
                <div class="absolute -bottom-12 left-6">
                  <div class="w-24 h-24 rounded-none border-4 border-black flex items-center justify-center shadow-sm"
                    style="background-color: <%= headerColor %>;">
                    <i class="fa-solid <%= iconClass %> text-5xl text-black drop-shadow-lg"></i>
                  </div>
                </div>
                <div
                  class="absolute top-4 right-4 bg-white border-2 border-black px-3 py-1 font-bold text-sm uppercase">
                  <%= project.status %>
                </div>
              </div>

              <div class="pt-14 pb-6 px-6 flex-grow">
                <h3 class="text-2xl font-black text-black mb-3">
                  <%= project.title %>
                </h3>

                <p class="text-gray-700 font-medium leading-relaxed mb-4">
                  <%= project.description %>
                </p>

                <div class="bg-gray-50 border-2 border-gray-200 p-3 mb-4">
                  <div class="text-xs text-gray-500 font-bold uppercase mb-1">Problem Solved</div>
                  <p class="text-gray-800 text-sm line-clamp-3 font-medium">
                    <%= project.problem %>
                  </p>
                </div>
                <div class="mb-4">
                  <p class="text-xs uppercase text-gray-600 font-bold mb-2">Tech Stack</p>
                  <div class="flex flex-wrap gap-2">
                    <% project.techStack.forEach(tech=> { %>
                      <span class="bg-black text-white text-xs px-2 py-1 font-bold border-2 border-black">
                        <%= tech %>
                      </span>
                      <% }); %>
                  </div>
                </div>

                <!-- Team Info -->
                <div class="bg-gray-50 border-2 border-gray-200 p-3 mb-4 flex items-center gap-3">
                  <div class="flex -space-x-2">
                    <% project.team.slice(0, 3).forEach(member=> { %>
                      <div
                        class="w-10 h-10 <%= member.color %> rounded-full border-2 border-black flex items-center justify-center text-xs font-bold">
                        <%= member.initials %>
                      </div>
                      <% }); %>
                  </div>
                  <div>
                    <div class="text-xs text-gray-500 font-bold uppercase">Team</div>
                    <div class="font-bold text-sm">
                      <%= project.teamCount %> members
                    </div>
                  </div>
                </div>

              </div>

              <!-- Footer Action Buttons -->
              <div class="p-4 border-t-4 border-black bg-gray-50 grid grid-cols-3 gap-2">
                <a href="<%= project.links.github %>"
                  class="bg-white hover:bg-gray-900 hover:text-white text-black text-center py-2 border-2 border-black font-bold text-sm transition-all">
                  <i class="fa-brands fa-github"></i>
                </a>
                <a href="<%= project.links.demo %>"
                  class="bg-white hover:bg-gray-900 hover:text-white text-black text-center py-2 border-2 border-black font-bold text-sm transition-all">
                  <i class="fa-solid fa-desktop"></i>
                </a>
                <a href="/v1/projects/<%= project.id %>"
                  class="bg-black text-white text-center py-2 border-2 border-black hover:bg-white hover:text-black font-bold text-sm transition-all">
                  VIEW
                </a>
              </div>
            </div>

            <% }); %>

        </div>

        <!-- Empty State (when no projects after filter) -->
        <div class="text-center py-16" id="emptyState" style="display: none;">
          <div class="text-6xl mb-4">📭</div>
          <h3 class="text-3xl font-black mb-3 text-black">NO PROJECTS FOUND</h3>
          <p class="text-gray-700 mb-6 font-medium text-lg">
            Try adjusting your filters or search terms.
          </p>
        </div>
      </div>

      <!-- Add Project CTA Section -->
      <div class="container mx-auto px-4 mb-20">
        <div
          class="bg-[#FF90E8] border-4 border-black p-12 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10 shadow-neo">
          <div class="flex-1">
            <h2 class="text-4xl md:text-5xl font-black mb-4 leading-tight text-black">GOT AN AMAZING <br> IDEA?</h2>
            <p class="text-xl font-bold text-black">Share your project with the community. Get feedback. Find
              collaborators.</p>
          </div>
          <div>
            <a href="/v1/projects/new"
              class="inline-block bg-black text-white text-xl font-bold px-8 py-4 border-4 border-black shadow-[4px_4px_0_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
              ADD YOUR PROJECT <i class="fa-solid fa-plus ml-2"></i>
            </a>
          </div>
        </div>
      </div>

    </main>

    <%- include('../partials/footer.ejs') %>

      <script src="/js/projects.js"></script>
</body>

</html>