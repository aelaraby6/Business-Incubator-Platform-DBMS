<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Projects & Ideas - Business Incubator Platform</title>
    <link href="/css/style.css" rel="stylesheet" />
  </head>

  <body class="bg-white text-gray-900 min-h-screen flex flex-col">
    <%- include('../partials/header.ejs') %>
    <main class="flex-1 px-4 py-12">
      <div class="max-w-7xl mx-auto">
        <!-- Header Section -->
        <div class="mb-12">
          <div
            class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8"
          >
            <div>
              <span class="text-sm uppercase tracking-widest text-gray-600"
                >Innovation Hub</span
              >
              <h1 class="text-4xl md:text-5xl font-bold mt-3 text-gray-900">
                Projects & Ideas
              </h1>
              <p class="text-gray-700 mt-3 max-w-2xl">
                Explore innovative projects and startup ideas from our incubator
                community. Collaborate, share, and bring your vision to life.
              </p>
            </div>
            <a
              href="/v1/projects/new"
              class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-lg font-semibold transition-colors whitespace-nowrap text-white"
            >
              + Add Project
            </a>
          </div>

          <!-- Search & Filter Section -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <input
              type="text"
              placeholder="Search projects..."
              class="col-span-1 md:col-span-2 bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            />
            <select
              class="bg-white border border-gray-300 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
            >
              <option value="">All Status</option>
              <option value="idea">Idea</option>
              <option value="in-progress">In Progress</option>
              <option value="completed">Completed</option>
            </select>
          </div>
        </div>

        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% projects.forEach(project => { %>
          
          <!-- Project Card -->
          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-blue-500 transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/10 group cursor-pointer project-card" data-status="<%= project.status.toLowerCase() %>" data-title="<%= project.title.toLowerCase() %>" data-description="<%= project.description.toLowerCase() %>" data-tech="<%= project.techStack.join(' ').toLowerCase() %>">
          
            <!-- Project Content -->
            <div class="p-6">
              <div class="flex items-start justify-between mb-3">
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                  <%= project.title %>
                </h3>
                <span class="bg-blue-100 border border-blue-300 text-blue-800 text-xs font-semibold px-3 py-1 rounded-full">
                  <%= project.status %>
                </span>
              </div>

              <p class="text-gray-700 text-sm mb-4">
                <%= project.description %>
              </p>

              <div class="mb-4 pb-4 border-b border-gray-200">
                <p class="text-xs uppercase text-gray-600 font-semibold mb-2">
                  Problem Solved
                </p>
                <p class="text-gray-800 text-sm line-clamp-3">
                  <%= project.problem %>
                </p>
              </div>

              <div class="mb-4">
                <p class="text-xs uppercase text-gray-600 font-semibold mb-2">
                  Tech Stack
                </p>
                <div class="flex flex-wrap gap-2">
                  <% project.techStack.forEach(tech => { %>
                  <span class="bg-gray-200 text-gray-800 text-xs px-2 py-1 rounded">
                    <%= tech %>
                  </span>
                  <% }); %>
                </div>
              </div>

              <div class="mb-4 pb-4 border-b border-gray-200">
                <p class="text-xs uppercase text-gray-600 font-semibold mb-2">
                  Team
                </p>
                <div class="flex items-center gap-2">
                  <div class="flex -space-x-2">
                    <% project.team.forEach(member => { %>
                    <div class="w-8 h-8 <%= member.color %> rounded-full border border-white flex items-center justify-center text-xs font-bold">
                      <%= member.initials %>
                    </div>
                    <% }); %>
                  </div>
                  <span class="text-sm text-gray-700"><%= project.teamCount %></span>
                </div>
              </div>

              <!-- Links -->
              <div class="flex gap-3">
                <a href="<%= project.links.github %>" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-900 text-center py-2 rounded-lg text-sm font-medium transition-colors">
                  GitHub
                </a>
                <a href="<%= project.links.demo %>" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-900 text-center py-2 rounded-lg text-sm font-medium transition-colors">
                  Demo
                </a>
                <a href="/v1/projects/<%= project.id %>" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-center py-2 rounded-lg text-sm font-medium transition-colors">
                  View
                </a>
              </div>
            </div>
          </div>
          
          <% }); %>

        </div>

        <!-- Empty State (when no projects) -->
        <div class="text-center py-16" style="display: none">
          <div class="text-6xl mb-4">📭</div>
          <h3 class="text-2xl font-bold mb-2 text-gray-900">No Projects Yet</h3>
          <p class="text-gray-700 mb-6">
            Be the first to share your amazing idea with the community!
          </p>
          <a
            href="/v1/projects/new"
            class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-lg font-semibold transition-colors inline-block text-white"
          >
            Create First Project
          </a>
        </div>
      </div>
    </main>
    <%- include('../partials/footer.ejs') %>
    <script src="/js/projects.js"></script>
  </body>
</html>