<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %> 

<body class="bg-neo-white flex flex-col min-h-screen text-neo-black">
    <%- include('../partials/header.ejs') %>

    <main class="flex-grow">

        <div class="container mx-auto px-4 py-12 md:py-20 text-center">
            <span class="bg-neo-black text-white px-4 py-1 font-bold text-xs md:text-sm uppercase tracking-widest mb-4 inline-block transform -rotate-2 font-display">
                Innovation Hub
            </span>
            <h1 class="text-5xl md:text-7xl font-bold text-neo-black mb-6 font-display uppercase tracking-tighter leading-none">
                Projects & <span class="bg-brand-indigo text-white px-2 md:px-4 border-4 border-black shadow-neo italic inline-block transform rotate-1">Ideas</span>
            </h1>
            <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto font-medium font-sans border-l-4 border-brand-indigo pl-4 md:pl-6 italic text-left md:text-center">
                 Explore innovative projects and startup ideas from our incubator community.
            </p>
        </div>

        <div class="container mx-auto px-4 mb-12">
            <div class="flex flex-col md:flex-row gap-4 max-w-5xl mx-auto">
                <div class="relative flex-grow">
                    <input type="text" id="searchInput" placeholder="Search projects..."
                        class="w-full bg-white border-4 border-black rounded-none px-6 py-4 text-neo-black placeholder-slate-400 focus:outline-none font-bold shadow-neo font-sans transition-all focus:-translate-y-1" />
                </div>
                <div class="relative w-full md:w-1/3">
                    <select id="statusFilter"
                        class="w-full bg-white border-4 border-black rounded-none px-6 py-4 text-neo-black focus:outline-none font-bold shadow-neo font-sans cursor-pointer appearance-none uppercase">
                        <option value="">All Status</option>
                        <option value="idea">Idea</option>
                        <option value="in-progress">In Progress</option>
                        <option value="completed">Completed</option>
                    </select>
                    <div class="absolute right-6 top-1/2 transform -translate-y-1/2 pointer-events-none text-black">
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="container mx-auto px-4 mb-24">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10" id="projectsGrid">

                <% projects.forEach(project=> {
                    let headerColorBg = 'bg-brand-indigo';
                    let lightBg = 'bg-indigo-50'; 
                    let accentBorder = 'border-brand-indigo'; 
                    let accentText = 'text-brand-indigo';
                    let iconClass = 'fa-lightbulb';
                    let textColor = 'text-white'; 

                    if (project.status.toLowerCase().includes('in-progress') || project.status.toLowerCase().includes('in progress')) {
                        headerColorBg = 'bg-brand-amber'; 
                        lightBg = 'bg-amber-50';
                        accentBorder = 'border-brand-amber';
                        accentText = 'text-amber-700';
                        iconClass = 'fa-rocket';
                        textColor = 'text-black'; 
                    } else if (project.status.toLowerCase() === 'completed') {
                        headerColorBg = 'bg-teal-600';
                        lightBg = 'bg-teal-50';
                        accentBorder = 'border-teal-600';
                        accentText = 'text-teal-700';
                        iconClass = 'fa-trophy';
                        textColor = 'text-white';
                    }
                %>

                <div class="bg-white border-4 border-black overflow-hidden shadow-neo flex flex-col h-full transform transition hover:-translate-y-2 duration-300 group project-card relative"
                     data-status="<%= project.status.toLowerCase() %>" 
                     data-title="<%= project.title.toLowerCase() %>"
                     data-description="<%= project.description.toLowerCase() %>"
                     data-tech="<%= project.techStack.join(' ').toLowerCase() %>">

                    <a href="/v1/projects/<%= project.id %>" class="flex flex-col flex-grow text-inherit no-underline hover:no-underline">
                        
                        <div class="h-32 border-b-4 border-black relative <%= headerColorBg %>"
                             style="background-image: radial-gradient(black 1px, transparent 1px); background-size: 10px 10px; opacity: 1;">
                            
                            <div class="absolute -bottom-12 left-6">
                                <div class="w-24 h-24 rounded-none border-4 border-black flex items-center justify-center shadow-sm <%= headerColorBg %>">
                                    <i class="fa-solid <%= iconClass %> text-5xl drop-shadow-lg <%= textColor %>"></i>
                                </div>
                            </div>

                            <div class="absolute top-4 right-4 bg-white border-2 border-black px-3 py-1 font-bold text-sm uppercase font-display tracking-wider shadow-[2px_2px_0_0_rgba(0,0,0,1)] text-black">
                                <%= project.status %>
                            </div>
                        </div>

                        <div class="pt-14 pb-6 px-6 flex-grow flex flex-col">
                            
                            <h3 class="text-2xl font-black text-neo-black mb-3 font-display uppercase tracking-tight leading-none break-words group-hover:<%= accentText %> transition-colors mt-2">
                                <%= project.title %>
                            </h3>

                            <p class="text-slate-700 font-bold font-sans leading-relaxed mb-6 line-clamp-3 text-sm border-l-4 <%= accentBorder %> pl-3">
                                <%= project.description %>
                            </p>

                            <div class="<%= lightBg %> border-l-4 <%= accentBorder %> border-y-2 border-r-2 border-slate-200 p-4 mb-5 relative">
                                <div class="text-[10px] <%= accentText %> font-black uppercase mb-1 font-display tracking-widest">Problem Solved</div>
                                <p class="text-gray-900 text-sm font-bold font-inter leading-snug line-clamp-2 italic">
                                    "<%= project.problem %>"
                                </p>
                            </div>

                            <div class="mt-auto mb-6">
                                <p class="text-[10px] uppercase text-gray-400 font-black mb-2 font-display tracking-widest">Tech Stack</p>
                                <div class="flex flex-wrap gap-2">
                                    <% project.techStack.forEach(tech=> { %>
                                        <span class="bg-black text-white text-[10px] px-2 py-1 font-bold border-2 border-black font-inter uppercase">
                                            <%= tech %>
                                        </span>
                                    <% }); %>
                                </div>
                            </div>

                            <div class="flex items-center gap-3 pt-4 border-t-4 border-black/5">
                                <div class="flex -space-x-3 overflow-hidden">
                                    <% project.team.slice(0, 3).forEach(member=> { %>
                                        <div class="w-8 h-8 <%= headerColorBg %> <%= textColor %> rounded-full border-2 border-black flex items-center justify-center text-[10px] font-black relative z-10 uppercase">
                                            <%= member.initials %>
                                        </div>
                                    <% }); %>
                                    <% if(project.team.length > 3) { %>
                                        <div class="w-8 h-8 bg-white text-black rounded-full border-2 border-black flex items-center justify-center text-[10px] font-black relative z-10">
                                            +<%= project.team.length - 3 %>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="text-xs font-bold text-gray-500 uppercase tracking-tight">
                                    <%= project.team.length %> Members
                                </div>
                            </div>
                        </div>
                    </a>

                    <div class="border-t-4 border-black bg-gray-100 grid grid-cols-2 divide-x-4 divide-black relative z-20">
                        <a href="<%= project.links.github %>" target="_blank"
                           class="col-span-1 bg-white hover:bg-black hover:text-white text-black flex items-center justify-center py-3 transition-colors group/btn">
                            <i class="fa-brands fa-github text-xl"></i>
                        </a>
                        <a href="<%= project.links.demo %>" target="_blank"
                           class="col-span-1 bg-white hover:bg-brand-indigo hover:text-white text-black flex items-center justify-center py-3 transition-colors group/btn">
                            <i class="fa-solid fa-desktop text-lg"></i>
                        </a>
                    </div>

                </div>
                <% }); %>

            </div>

            <div class="text-center py-24 border-4 border-black bg-white shadow-neo" id="emptyState" style="display: none;">
                <div class="text-8xl mb-6 opacity-50 grayscale">📭</div>
                <h3 class="text-4xl font-black mb-4 text-neo-black font-display uppercase tracking-tighter">No Projects Found</h3>
                <p class="text-gray-600 mb-8 font-medium text-xl max-w-md mx-auto font-inter">
                     We couldn't find what you're looking for. Try adjusting your filters or search terms.
                </p>
                <button onclick="resetFilters()" class="bg-neo-black text-white px-10 py-4 border-4 border-black font-black hover:bg-white hover:text-black transition-all shadow-neo hover:shadow-none uppercase tracking-widest">
                    RESET FILTERS
                </button>
            </div>
        </div>

        <div class="container mx-auto px-4 mb-24">
            <div class="bg-brand-slate border-4 border-black p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10 shadow-neo relative overflow-hidden">
                <div class="flex-1 relative z-10 text-center md:text-left">
                    <h2 class="text-4xl md:text-5xl font-black mb-4 leading-tight text-white font-display uppercase tracking-tighter">
                        GOT AN INNOVATIVE <br> <span class="text-brand-amber">IDEA?</span>
                    </h2>
                    <p class="text-lg md:text-xl font-bold text-slate-400 font-sans max-w-xl italic">
                         Submit your project definition. Get incubated. Build the future.
                    </p>
                </div>
                <div class="relative z-10 w-full md:w-auto">
                    <a href="/v1/projects/new"
                       class="flex items-center justify-center bg-white text-black text-lg md:text-xl font-black px-10 py-5 border-4 border-black shadow-[6px_6px_0_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all font-display tracking-widest w-full md:w-auto uppercase">
                        CREATE PROJECT <i class="fa-solid fa-arrow-right ml-3"></i>
                    </a>
                </div>
                <div class="absolute top-0 right-0 w-64 h-64 bg-brand-indigo/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            </div>
        </div>

    </main>

    <%- include('../partials/footer.ejs') %>
    <script src="/js/projects.js"></script>
</body>
</html>