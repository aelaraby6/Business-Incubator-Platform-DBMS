<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Business Incubator</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet"/>
    
    <link href="/css/style.css" rel="stylesheet" />
</head>
<body class="bg-[#FFFDF5] flex flex-col min-h-screen"> 
    <%- include('../partials/header.ejs') %>

    <main class="flex-grow">
        
        <div class="container mx-auto px-4 py-16 text-center">
            <span class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-4 inline-block transform -rotate-2">
                Expert Guidance
            </span>
            <h1 class="text-6xl md:text-7xl font-bold text-black mb-6">
                MEET THE <span class="bg-[#5465FF] text-white px-2 border-4 border-black shadow-neo italic">WIZARDS</span>
            </h1>
            <p class="text-xl text-gray-700 max-w-2xl mx-auto font-medium">
                Don't learn from mistakes. Learn from people who already made them.
            </p>
        </div>

        <div class="bg-[#FF90E8] border-y-4 border-black py-3 mb-16 marquee-container">
            <div class="marquee-content text-xl font-bold uppercase tracking-wider text-black">
                Javascript • Python • Rust • GoLang • Docker • Kubernetes • AWS • Azure • React • Vue • Angular • System Design • Microservices •  
                Javascript • Python • Rust • GoLang • Docker • Kubernetes • AWS • Azure • React • Vue • Angular • System Design • Microservices •
            </div>
        </div>

        <div class="container mx-auto px-4 mb-24">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                
                <% mentors.forEach(mentor => { %>
                    <div class="bg-white border-4 border-black rounded-xl overflow-hidden shadow-neo flex flex-col h-full transform transition hover:-translate-y-2 duration-300 group">
                        
                        <div class="h-28 border-b-4 border-black relative" 
                             style="background-color: <%= mentor.color %>; background-image: radial-gradient(black 1px, transparent 1px); background-size: 10px 10px; opacity: 0.9;">
                            <div class="absolute -bottom-10 left-6">
                                <img src="<%= mentor.image %>" alt="<%= mentor.name %>" class="w-24 h-24 rounded-none border-4 border-black bg-white object-cover shadow-sm">
                            </div>
                            <button class="absolute top-4 right-4 bg-white border-2 border-black w-8 h-8 flex items-center justify-center hover:bg-black hover:text-white transition-colors">
                                <i class="fa-regular fa-bookmark"></i>
                            </button>
                        </div>

                        <div class="pt-12 pb-6 px-6 flex-grow">
                            <h3 class="text-2xl font-black text-black mb-1"><%= mentor.name %></h3>
                            <div class="flex items-center gap-2 mb-4">
                                <span class="text-sm font-bold bg-black text-white px-2 py-0.5"><%= mentor.role %></span>
                                <span class="text-sm font-bold">@ <%= mentor.company %></span>
                            </div>
                            <p class="text-gray-700 font-medium leading-relaxed border-l-4 border-gray-200 pl-3 mb-4">
                                "<%= mentor.bio %>"
                            </p>
                            <div class="inline-flex items-center gap-2 bg-green-100 border-2 border-green-800 px-3 py-1 rounded-full text-green-800 text-xs font-bold">
                                <span class="w-2 h-2 bg-green-600 rounded-full animate-pulse"></span>
                                Available this week
                            </div>
                        </div>

                        <div class="p-4 border-t-4 border-black bg-gray-50 flex justify-between items-center gap-4">
                            <div class="flex space-x-2">
                                <a href="#" class="text-black hover:text-[#0077b5] transition-colors"><i class="fa-brands fa-linkedin text-2xl"></i></a>
                                <a href="#" class="text-black hover:text-gray-600 transition-colors"><i class="fa-brands fa-github text-2xl"></i></a>
                            </div>
                            <button class="flex-grow bg-black text-white font-bold py-2 border-2 border-transparent hover:bg-white hover:text-black hover:border-black transition-all">
                                BOOK SESSION
                            </button>
                        </div>
                    </div>
                <% }) %>

            </div>
        </div>

        <div class="bg-[#5465FF] border-y-4 border-black py-20 mb-20 text-white">
            <div class="container mx-auto px-4 max-w-6xl">
                <h2 class="text-5xl font-black text-center mb-16 text-white drop-shadow-[4px_4px_0_#000]">HOW TO GET MENTORED</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="bg-white text-black border-4 border-black p-8 shadow-[8px_8px_0_0_#000]">
                        <div class="text-6xl font-black text-[#E0E7FF] mb-4">01</div>
                        <h3 class="text-2xl font-bold mb-3">Pick Your Fighter</h3>
                        <p class="font-medium">Browse our list of legends. Filter by stack, company, or vibe.</p>
                    </div>
                    <div class="bg-white text-black border-4 border-black p-8 shadow-[8px_8px_0_0_#000] relative top-4 md:top-8">
                        <div class="text-6xl font-black text-[#E0E7FF] mb-4">02</div>
                        <h3 class="text-2xl font-bold mb-3">Book a Slot</h3>
                        <p class="font-medium">Sync calendars. Pay with coffee (or credit). It's seamless.</p>
                    </div>
                    <div class="bg-white text-black border-4 border-black p-8 shadow-[8px_8px_0_0_#000] relative top-8 md:top-16">
                        <div class="text-6xl font-black text-[#E0E7FF] mb-4">03</div>
                        <h3 class="text-2xl font-bold mb-3">Level Up</h3>
                        <p class="font-medium">Get grilled, get advice, get better. Repeat until you are the senior.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="container mx-auto px-4 mb-20">
            <div class="bg-[#FFDE59] border-4 border-black p-12 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10 shadow-neo">
                <div class="flex-1">
                    <h2 class="text-4xl md:text-5xl font-black mb-4 leading-tight">ARE YOU A SENIOR <br> DEVELOPER?</h2>
                    <p class="text-xl font-bold text-gray-800">Pass on the torch. Help the next generation write clean code.</p>
                </div>
                <div>
                    <a href="#" class="inline-block bg-white text-black text-xl font-bold px-8 py-4 border-4 border-black shadow-[4px_4px_0_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
                        APPLY AS MENTOR <i class="fa-solid fa-arrow-right ml-2"></i>
                    </a>
                </div>
            </div>
        </div>

    </main>

    <%- include('../partials/footer.ejs') %>
</body>
</html>