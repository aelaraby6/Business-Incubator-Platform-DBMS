<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head') %>
  <body class="bg-[#FFFDF5] flex flex-col min-h-screen">
    <%- include('../partials/header.ejs') %>

    <main class="flex-grow">
      <div class="container mx-auto px-4 py-16 text-center">
        <span
          class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-4 inline-block transform -rotate-2 font-display"
        >
          Learn & Grow
        </span>
        <h1
          class="text-6xl md:text-7xl font-bold text-black mb-6 font-display tracking-tight"
        >
          UPCOMING
          <span
            class="bg-indigo-700 text-white px-4 border-4 border-black shadow-neo italic inline-block"
            >WORKSHOPS</span
          >
        </h1>
        <p
          class="text-xl text-gray-700 max-w-2xl mx-auto font-medium font-inter"
        >
          Level up your skills with hands-on training from industry experts.
        </p>
      </div>

      <div class="container mx-auto px-4 mb-12 pt-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto">
          <div class="col-span-1 md:col-span-2 relative">
            <input
              type="text"
              id="searchInput"
              placeholder="Search by topic or trainer..."
              class="w-full bg-white border-4 border-black rounded-none px-4 py-3 text-black placeholder-gray-500 focus:outline-none font-bold shadow-[4px_4px_0_0_#000] font-inter focus:bg-gray-50 transition-colors"
            />
            <i
              class="fa-solid fa-magnifying-glass absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400"
            ></i>
          </div>

          <select
            id="categoryFilter"
            class="bg-white border-4 border-black rounded-none px-4 py-3 text-black focus:outline-none font-bold shadow-[4px_4px_0_0_#000] font-inter cursor-pointer"
          >
            <option value="">All Categories</option>
            <option value="product">Product Development</option>
            <option value="marketing">Marketing & Growth</option>
            <option value="finance">Finance</option>
            <option value="strategy">Strategy</option>
            <option value="legal">Legal</option>
          </select>
        </div>
      </div>

      <div class="container mx-auto px-4 mb-24">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10"
          id="workshopsGrid"
        >
          <% workshops.forEach((workshop) => { %>
            <div
              class="workshop-card bg-white border-4 border-black rounded-xl overflow-hidden shadow-neo flex flex-col h-full transform transition hover:-translate-y-2 duration-300 group cursor-pointer"
              data-title="<%= workshop.title %>"
              data-category="<%= workshop.category || 'general' %>"
              data-trainer="<%= workshop.mentor_name || 'TBA' %>"
              data-workshop-id="<%= workshop.id %>"
            >
              <div
                class="h-32 border-b-4 border-black relative bg-indigo-700"
                style="
                  background-image: radial-gradient(black 1px, transparent 1px);
                  background-size: 10px 10px;
                  opacity: 1;
                "
              >
                <div class="absolute -bottom-12 left-6">
                  <div
                    class="w-24 h-24 rounded-none border-4 border-black flex items-center justify-center shadow-sm bg-indigo-700"
                  >
                    <i
                      class="fa-solid fa-rocket text-5xl text-white drop-shadow-lg"
                    ></i>
                  </div>
                </div>
                <div
                  class="absolute top-4 right-4 bg-white border-2 border-black px-3 py-1 font-bold text-sm font-display"
                >
                  <i class="fa-solid fa-users mr-1"></i> <%= workshop.enrolled_count || 0 %>/30 SEATS
                </div>
              </div>

              <div class="pt-14 pb-6 px-6 flex-grow">
                <h3 class="text-2xl font-black text-black mb-2 font-display">
                  <%= workshop.title %>
                </h3>
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  <span
                    class="text-sm font-bold bg-black text-white px-2 py-0.5 border border-black"
                    ><%= workshop.category || 'General' %></span
                  >
                </div>
                <p
                  class="text-gray-700 font-medium leading-relaxed mb-4 font-inter"
                >
                  <%= workshop.description?.substring(0, 100) %>...
                </p>
                <div
                  class="bg-gray-50 border-2 border-gray-200 p-3 mb-4 flex items-center gap-3"
                >
                  <div
                    class="w-10 h-10 bg-gray-200 border-2 border-black rounded-full flex items-center justify-center font-bold"
                  >
                    <%= (workshop.mentor_name || 'T')[0] %>
                  </div>
                  <div>
                    <div
                      class="text-xs text-gray-500 font-bold uppercase font-display"
                    >
                      Trainer
                    </div>
                    <div class="font-bold text-sm"><%= workshop.mentor_name || 'TBA' %></div>
                  </div>
                </div>
                <div class="space-y-2 mb-4">
                  <div class="flex items-center gap-2 text-sm font-bold">
                    <i class="fa-solid fa-calendar text-indigo-700"></i
                    ><span>
                      <% if (workshop.start_date) { %>
                        <%= new Date(workshop.start_date).toLocaleDateString('en-US', {month: 'short', day: 'numeric', year: 'numeric'}) %>
                      <% } else { %>
                        TBD
                      <% } %>
                    </span>
                  </div>
                  <div class="flex items-center gap-2 text-sm font-bold">
                    <i class="fa-solid fa-location-dot text-gray-500"></i
                    ><span><%= workshop.location || 'TBA' %></span>
                  </div>
                </div>
                <div
                  class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold
                  <%= workshop.status === 'active' ? 'bg-green-100 border-2 border-green-800 text-green-800' : 
                      workshop.status === 'completed' ? 'bg-gray-100 border-2 border-gray-800 text-gray-800' : 
                      'bg-blue-100 border-2 border-blue-800 text-blue-800' %>"
                >
                  <span class="w-2 h-2 rounded-full <%= workshop.status === 'active' ? 'bg-green-600 animate-pulse' : 'bg-gray-600' %>"></span>
                  <%= workshop.status ? workshop.status.charAt(0).toUpperCase() + workshop.status.slice(1) : 'Scheduled' %>
                </div>
              </div>
              <div class="p-4 border-t-4 border-black bg-gray-50">
                <button
                  class="w-full bg-black text-white font-bold py-3 border-2 border-transparent hover:bg-white hover:text-black hover:border-black transition-all font-display tracking-wide view-workshop"
                  data-workshop-id="<%= workshop.id %>"
                >
                  <i class="fa-solid fa-eye mr-2"></i>VIEW DETAILS
                </button>
              </div>
            </div>
          <% }); %>
        </div>

        <div
          class="text-center py-24 border-4 border-black bg-white shadow-neo mt-10 hidden"
          id="emptyState"
        >
          <div class="text-7xl mb-6 opacity-50">🧐</div>
          <h3
            class="text-4xl font-black mb-4 text-black font-display uppercase"
          >
            No Workshops Found
          </h3>
          <p
            class="text-gray-700 mb-8 font-medium text-xl max-w-md mx-auto font-inter"
          >
            Try adjusting your search or category filter.
          </p>
          <button
            id="resetFilters"
            class="bg-black text-white px-8 py-3 border-2 border-black font-bold hover:bg-white hover:text-black transition-all shadow-[4px_4px_0_0_#000] hover:shadow-none"
          >
            CLEAR FILTERS
          </button>
        </div>
      </div>

      <div class="bg-slate-900 border-y-4 border-black py-20 mb-20 text-white">
        <div class="container mx-auto px-4 max-w-6xl">
          <h2
            class="text-5xl font-black text-center mb-16 drop-shadow-[4px_4px_0_#000] font-display"
          >
            HOW TO JOIN
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div
              class="bg-white text-black border-4 border-black p-8 shadow-[8px_8px_0_0_#FFF]"
            >
              <div class="text-6xl font-black text-slate-200 mb-4 font-display">
                01
              </div>
              <h3 class="text-2xl font-bold mb-3 font-display">
                Browse & Pick
              </h3>
              <p class="font-medium font-inter">
                Check out upcoming workshops. Find what matches your goals.
              </p>
            </div>
            <div
              class="bg-white text-black border-4 border-black p-8 shadow-[8px_8px_0_0_#FFF] relative top-4 md:top-8"
            >
              <div class="text-6xl font-black text-slate-200 mb-4 font-display">
                02
              </div>
              <h3 class="text-2xl font-bold mb-3 font-display">Click Attend</h3>
              <p class="font-medium font-inter">
                Reserve your seat. Get confirmation. Mark your calendar.
              </p>
            </div>
            <div
              class="bg-white text-black border-4 border-black p-8 shadow-[8px_8px_0_0_#FFF] relative top-8 md:top-16"
            >
              <div class="text-6xl font-black text-slate-200 mb-4 font-display">
                03
              </div>
              <h3 class="text-2xl font-bold mb-3 font-display">
                Show Up & Learn
              </h3>
              <p class="font-medium font-inter">
                Take notes. Ask questions. Apply what you learn to your startup.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="container mx-auto px-4 mb-20">
        <div
          class="bg-gray-900 border-4 border-black p-12 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10 shadow-neo"
        >
          <div class="flex-1">
            <h2
              class="text-4xl md:text-5xl font-black mb-4 leading-tight text-white font-display"
            >
              WANT TO HOST <br />
              A WORKSHOP?
            </h2>
            <p class="text-xl font-bold text-gray-300 font-inter">
              Share your expertise. Help entrepreneurs build better startups.
            </p>
          </div>
          <div>
            <a href="mailto:admin@incubator.com?subject=Mentorship Application" 
   class="inline-block bg-white text-black text-xl font-black px-10 py-5 border-4 border-black shadow-[4px_4px_0px_0px_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all uppercase">
    Contact to Join 📧
</a>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/footer.ejs') %>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("searchInput");
        const categoryFilter = document.getElementById("categoryFilter");
        const cards = document.querySelectorAll(".workshop-card");
        const emptyState = document.getElementById("emptyState");
        const resetBtn = document.getElementById("resetFilters");

        function filterWorkshops() {
          const searchTerm = searchInput.value.toLowerCase();
          const selectedCategory = categoryFilter.value.toLowerCase();
          let visibleCount = 0;

          cards.forEach((card) => {
            const title = card.getAttribute("data-title").toLowerCase();
            const trainer = card.getAttribute("data-trainer").toLowerCase();
            const category = card.getAttribute("data-category").toLowerCase();

            const matchesSearch =
              title.includes(searchTerm) || trainer.includes(searchTerm);
            const matchesCategory =
              selectedCategory === "" || category === selectedCategory;

            if (matchesSearch && matchesCategory) {
              card.style.display = "flex";
              visibleCount++;
            } else {
              card.style.display = "none";
            }
          });

          if (visibleCount === 0) {
            emptyState.classList.remove("hidden");
          } else {
            emptyState.classList.add("hidden");
          }
        }

        // Add click handlers to workshop cards and view details buttons
        cards.forEach((card) => {
          card.style.cursor = "pointer";
          
          // Make entire card clickable
          card.addEventListener("click", function (e) {
            if (!e.target.closest(".view-workshop")) {
              const workshopId = this.getAttribute("data-workshop-id");
              if (workshopId) {
                window.location.href = `/v1/workshop/${workshopId}`;
              }
            }
          });
        });

        // Handle view details button clicks
        document.querySelectorAll(".view-workshop").forEach((btn) => {
          btn.addEventListener("click", function (e) {
            e.stopPropagation();
            const workshopId = this.getAttribute("data-workshop-id");
            if (workshopId) {
              window.location.href = `/v1/workshop/${workshopId}`;
            }
          });
        });

        // Event Listeners
        searchInput.addEventListener("input", filterWorkshops);
        categoryFilter.addEventListener("change", filterWorkshops);

        resetBtn.addEventListener("click", () => {
          searchInput.value = "";
          categoryFilter.value = "";
          filterWorkshops();
        });
      });
    </script>
  </body>
</html>
