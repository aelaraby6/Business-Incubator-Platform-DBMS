<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>

<body class="min-h-screen flex flex-col bg-neo-white text-neo-black font-sans">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 px-4 py-12">
        <div class="w-full max-w-5xl mx-auto">
            <a href="/v1/projects"
                class="inline-flex items-center gap-3 mb-10 text-lg font-black uppercase tracking-widest hover:-translate-x-2 transition-transform group font-display">
                <span
                    class="w-10 h-10 border-4 border-black bg-brand-amber flex items-center justify-center shadow-neo-sm group-hover:shadow-none transition-all">←</span>
                Back to Projects
            </a>

            <div class="mb-16 text-center">
                <div
                    class="inline-block bg-brand-indigo px-6 py-2 border-4 border-black font-black text-xs mb-6 shadow-neo uppercase tracking-widest transform -rotate-1">
                    SECURE FUNDING
                </div>
                <h1
                    class="text-5xl md:text-7xl font-display font-bold text-neo-black mb-6 uppercase tracking-tighter">
                    Request <span class="text-brand-indigo italic">Funding</span>
                </h1>
                <p
                    class="text-xl text-slate-600 max-w-2xl mx-auto font-medium italic border-l-4 border-brand-indigo pl-6">
                    Tell us how much funding you need and what stage your project is in. Our review team will evaluate
                    your request.
                </p>
            </div>

            <!-- Flash Messages -->
            <% if (error) { %>
            <div class="bg-red-100 border-4 border-red-600 p-6 shadow-neo mb-8">
                <div class="flex items-center gap-4">
                    <span class="text-3xl">⚠️</span>
                    <div>
                        <h3 class="text-red-800 font-black uppercase font-display">Error</h3>
                        <p class="text-red-700 font-medium font-sans">
                            <%= error %>
                        </p>
                    </div>
                </div>
            </div>
            <% } %>

            <% if (success) { %>
            <div class="bg-green-100 border-4 border-green-600 p-6 shadow-neo mb-8">
                <div class="flex items-center gap-4">
                    <span class="text-3xl">✅</span>
                    <div>
                        <h3 class="text-green-800 font-black uppercase font-display">Success</h3>
                        <p class="text-green-700 font-medium font-sans">
                            <%= success %>
                        </p>
                    </div>
                </div>
            </div>
            <% } %>

            <form action="/v1/funding/create" method="POST" class="space-y-12" id="fundingForm">

                <!-- Section 1: Select Project -->
                <div class="bg-white border-4 border-black p-8 md:p-10 shadow-neo relative">
                    <div class="flex items-center gap-4 mb-10">
                        <div
                            class="w-14 h-14 bg-brand-indigo text-white border-4 border-black flex items-center justify-center text-2xl font-black shadow-neo-sm">
                            1</div>
                        <h2 class="text-3xl font-display font-bold uppercase tracking-tight">
                            Select Your Project
                        </h2>
                    </div>

                    <div class="space-y-4 text-left">
                        <% if (projects && projects.length > 0) { %>
                        <div>
                            <label for="project_id"
                                class="block text-xs font-black uppercase mb-3 tracking-widest text-slate-500">Project
                                <span class="text-brand-indigo">*</span></label>
                            <select id="project_id" name="project_id" required
                                class="w-full px-4 py-3 border-4 border-black bg-white text-neo-black font-bold text-base focus:outline-none focus:ring-4 focus:ring-brand-indigo shadow-neo-sm hover:shadow-neo transition-all">
                                <option value="">-- Choose a project --</option>
                                <% projects.forEach(project => { %>
                                <option value="<%= project.id %>">
                                    <%= project.name %> (<%= project.domain %>)
                                </option>
                                <% }); %>
                            </select>
                            <p class="text-slate-600 text-sm font-medium mt-2">Select the project you want to request
                                funding for</p>
                        </div>
                        <% } else { %>
                        <div class="bg-yellow-50 border-4 border-brand-amber p-6">
                            <p class="font-black uppercase text-brand-amber mb-2">No Projects Found</p>
                            <p class="text-slate-600 font-medium mb-4">You need to create a project first before requesting
                                funding.</p>
                            <a href="/v1/projects/new"
                                class="inline-block bg-brand-amber border-4 border-black px-6 py-2 font-black text-neo-black uppercase shadow-neo hover:shadow-none hover:translate-x-1 transition-all">
                                Create a Project
                            </a>
                        </div>
                        <% } %>
                    </div>
                </div>

                <!-- Section 2: Funding Details -->
                <% if (projects && projects.length > 0) { %>
                <div class="bg-white border-4 border-black p-8 md:p-10 shadow-neo relative">
                    <div class="flex items-center gap-4 mb-10">
                        <div
                            class="w-14 h-14 bg-brand-amber text-neo-black border-4 border-black flex items-center justify-center text-2xl font-black shadow-neo-sm">
                            2</div>
                        <h2 class="text-3xl font-display font-bold uppercase tracking-tight">
                            Funding Details
                        </h2>
                    </div>

                    <div class="space-y-8 text-left">
                        <!-- Amount -->
                        <div>
                            <label for="amount"
                                class="block text-xs font-black uppercase mb-3 tracking-widest text-slate-500">Funding
                                Amount (USD) <span class="text-brand-indigo">*</span></label>
                            <div class="relative">
                                <span
                                    class="absolute left-6 top-1/2 -translate-y-1/2 text-2xl font-black text-slate-700 pointer-events-none">$</span>
                                <input type="number" id="amount" name="amount" placeholder="50000" step="0.01" min="0"
                                    required
                                    class="w-full pl-20 pr-4 py-3 border-4 border-black text-neo-black font-bold text-base focus:outline-none focus:ring-4 focus:ring-brand-indigo shadow-neo-sm hover:shadow-neo transition-all">
                            </div>
                            <p class="text-slate-600 text-sm font-medium mt-2">Enter the amount of funding you're
                                requesting</p>
                        </div>

                        <!-- Funding Stage -->
                        <div>
                            <label for="funding_stage"
                                class="block text-xs font-black uppercase mb-3 tracking-widest text-slate-500">Funding
                                Stage <span class="text-brand-indigo">*</span></label>
                            <select id="funding_stage" name="funding_stage" required
                                class="w-full px-4 py-3 border-4 border-black bg-white text-neo-black font-bold text-base focus:outline-none focus:ring-4 focus:ring-brand-indigo shadow-neo-sm hover:shadow-neo transition-all">
                                <option value="">-- Select funding stage --</option>
                                <option value="Pre-Seed">Pre-Seed</option>
                                <option value="Seed">Seed Round</option>
                                <option value="Series A">Series A</option>
                                <option value="Series B">Series B</option>
                                <option value="Series C">Series C</option>
                                <option value="Growth">Growth Stage</option>
                            </select>
                            <p class="text-slate-600 text-sm font-medium mt-2">Select the funding round your project is
                                in</p>
                        </div>

                        <!-- Description -->
                        <div>
                            <label for="description"
                                class="block text-xs font-black uppercase mb-3 tracking-widest text-slate-500">Use of
                                Funds (Optional)</label>
                            <textarea id="description" name="description" rows="6" placeholder="Explain how you'll use the funding..."
                                class="w-full px-4 py-3 border-4 border-black text-neo-black font-medium text-base focus:outline-none focus:ring-4 focus:ring-brand-indigo shadow-neo-sm hover:shadow-neo transition-all resize-none"></textarea>
                            <p class="text-slate-600 text-sm font-medium mt-2">Describe how you plan to use the
                                funding (e.g., product development, marketing, hiring)</p>
                        </div>
                    </div>
                </div>

                <!-- Submit Section -->
                <div class="bg-white border-4 border-black p-8 md:p-10 shadow-neo">
                    <div class="flex flex-col sm:flex-row gap-4 justify-between items-center">
                        <p class="text-slate-600 font-medium text-center sm:text-left">
                            <span class="font-black text-neo-black">Note:</span> A member of our team will review your
                            request within 5-7 business days.
                        </p>
                        <button type="submit"
                            class="px-8 py-3 bg-brand-indigo text-white border-4 border-black font-black uppercase text-lg shadow-neo hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all active:translate-x-0 active:translate-y-0 active:shadow-none whitespace-nowrap">
                            Submit Request
                        </button>
                    </div>
                </div>

            </form>
            <% } %>

        </div>
    </main>

    <%- include('../partials/footer.ejs') %>
</body>

</html>
