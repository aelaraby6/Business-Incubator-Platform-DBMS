<% const SocialLinks = {
  twitter: "https://twitter.com",
  youtube: "https://youtube.com",
  instagram: "https://instagram.com",
  facebook: "https://facebook.com",
  pinterest: "https://pinterest.com"
}; %>

<footer class="bg-black text-white pt-16 pb-8 px-4">
  <div class="max-w-7xl mx-auto flex flex-col gap-12">
    <div class="flex flex-col lg:flex-row gap-12 w-full">
      <div
        class="flex flex-col md:flex-row w-full justify-between items-start gap-8 md:gap-0"
      >
        <div class="flex-1 flex flex-col justify-center mb-8 md:mb-0 max-w-2xl">
          <h2
            class="text-2xl xs:text-3xl sm:text-4xl md:text-5xl font-bold mb-6 leading-tight"
          >
            Subscribe to get tips and tactics to grow the way you want.
          </h2>
          <form class="flex w-full max-w-xl mb-4">
            <input
              type="email"
              placeholder="Your email address"
              class="flex-1 px-4 py-3 rounded-l bg-black border border-gray-700 text-base sm:text-lg text-gray-200 focus:outline-none focus:border-pink-400"
            />
            <button
              type="submit"
              class="px-6 py-3 rounded-r bg-[var(--primary-accent)] text-black font-bold text-lg sm:text-xl hover:bg-pink-300 transition opacity-50 hover:opacity-100"
            >
              →
            </button>
          </form>
        </div>
        <div class="flex flex-col lg:flex-row gap-0 lg:gap-32 w-full lg:w-auto">
          <div class="flex flex-col gap-1 min-w-25 text-base sm:text-lg">
            <a href="#" class="hover:underline">Discover</a>
            <a href="#" class="hover:underline">Blog</a>
            <a href="#" class="hover:underline">Pricing</a>
            <a href="#" class="hover:underline">Features</a>
            <a href="#" class="hover:underline">About</a>
            <a href="#" class="hover:underline">Small Bets</a>
          </div>
          <div class="flex flex-col gap-1 min-w-30 text-base sm:text-lg">
            <a href="#" class="hover:underline">Help</a>
            <a href="#" class="hover:underline">Board meetings</a>
            <a href="#" class="hover:underline">Terms of Service</a>
            <a href="#" class="hover:underline">Privacy Policy</a>
          </div>
        </div>
      </div>
    </div>
    <div
      class="flex flex-col md:flex-row justify-between items-center mt-8 gap-6"
    >
      <span class="text-gray-400"
        >© <%= new Date().getFullYear() %> Incubation</span
      >
      <div class="flex gap-8 text-2xl">
        <% Object.entries(SocialLinks).forEach(([platform, url]) => { %>
          <a href="<%= url %>" target="_blank" rel="noopener noreferrer" aria-label="<%= platform %>" class="hover:text-(--primary-accent) transition">
            <i class="fa-brands fa-<%= platform %>"></i>
          </a>
        <% }); %>
      </div>
    </div>
  </div>
</footer>
