<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In</title>
    <link href="/css/style.css" rel="stylesheet" />
  </head>
  <body class="bg-black text-white min-h-screen flex flex-col">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <div class="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-10">
        <section class="flex flex-col justify-center">
          <span class="text-sm uppercase tracking-widest text-gray-400"
            >Welcome back</span
          >
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mt-3">
            Sign in to your account
          </h1>
          <p class="text-gray-400 mt-4 text-base sm:text-lg">
            Manage your incubator journey, track progress, and access your
            dashboard.
          </p>
        </section>

        <section
          class="bg-neutral-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl"
        >
          <form class="space-y-5">
            <div>
              <label class="block text-sm text-gray-300 mb-2" for="email"
                >Email</label
              >
              <input
                id="email"
                type="email"
                placeholder="you@example.com"
                class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]"
              />
            </div>

            <div>
              <label class="block text-sm text-gray-300 mb-2" for="password"
                >Password</label
              >
              <input
                id="password"
                type="password"
                placeholder="••••••••"
                class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]"
              />
            </div>

            <div
              class="flex items-center justify-between text-sm text-gray-400"
            >
              <label class="flex items-center gap-2">
                <input type="checkbox" class="accent-[var(--primary-accent)]" />
                Remember me
              </label>
              <a href="#" class="hover:text-white">Forgot password?</a>
            </div>

            <button
              type="submit"
              class="w-full py-3 rounded-lg bg-[var(--primary-accent)] text-black font-semibold hover:opacity-90 transition"
            >
              Sign In
            </button>

            <p class="text-sm text-gray-400 text-center">
              Don’t have an account?
              <a href="<%= routes.signupRoute %>" class="text-white hover:underline"
                >Create one</a
              >
            </p>
          </form>
        </section>
      </div>
    </main>

    <%- include('../partials/footer.ejs') %>
  </body>
</html>
