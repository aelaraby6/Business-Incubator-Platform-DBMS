<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign Up</title>
  <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-black text-white min-h-screen flex flex-col">

  <%- include('../partials/header.ejs') %>

    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <div class="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-10">
        <section class="flex flex-col justify-center">
          <span class="text-sm uppercase tracking-widest text-gray-400">Get started</span>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mt-3">
            Create your account
          </h1>
          <p class="text-gray-400 mt-4 text-base sm:text-lg">
            Join the incubator platform to track milestones, access resources,
            and connect with mentors.
          </p>
        </section>

        <section class="bg-neutral-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl">

          <!-- Error Message -->
          <div id="errorMessage"
            class="hidden bg-red-900/20 border border-red-500 rounded-2xl p-4 mb-5 flex items-start gap-3">
            <svg class="w-6 h-6 text-red-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor"
              viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div class="flex-1">
              <h3 class="text-red-500 font-semibold mb-1">Error</h3>
              <p id="errorText" class="text-red-300 text-sm"></p>
            </div>
          </div>

          <!-- Success Message -->
          <% if (typeof success !=='undefined' && success) { %>
            <div class="bg-green-900/20 border border-green-500 rounded-2xl p-4 mb-5 flex items-start gap-3">
              <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor"
                viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="flex-1">
                <h3 class="text-green-500 font-semibold mb-1">Success</h3>
                <p class="text-green-300 text-sm">
                  <%= success %>
                </p>
              </div>
            </div>
            <% } %>

              <!-- Error Message) -->
              <% if (typeof error !=='undefined' && error) { %>
                <div class="bg-red-900/20 border border-red-500 rounded-2xl p-4 mb-5 flex items-start gap-3">
                  <svg class="w-6 h-6 text-red-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div class="flex-1">
                    <h3 class="text-red-500 font-semibold mb-1">Error</h3>
                    <p class="text-red-300 text-sm">
                      <%= error %>
                    </p>
                  </div>
                </div>
                <% } %>

                  <form id="signupForm" action="/v1/auth/register" method="POST" class="space-y-5">
                    <!-- Full Name -->
                    <div>
                      <label class="block text-sm text-gray-300 mb-2" for="name">Full name</label>
                      <input id="name" name="name" type="text" placeholder="Your name" required
                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                    </div>

                    <!-- Email -->
                    <div>
                      <label class="block text-sm text-gray-300 mb-2" for="email">Email</label>
                      <input id="email" name="email" type="email" placeholder="you@example.com" required
                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                    </div>

                    <!-- Password -->
                    <div>
                      <label class="block text-sm text-gray-300 mb-2" for="password">Password</label>
                      <input id="password" name="password" type="password" placeholder="Create a strong password"
                        required
                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                      <p class="text-xs text-gray-500 mt-2">Password must be at least 8 characters</p>
                    </div>

                    <!-- Confirm Password -->
                    <div>
                      <label class="block text-sm text-gray-300 mb-2" for="confirmPassword">Confirm Password</label>
                      <input id="confirmPassword" name="confirmPassword" type="password"
                        placeholder="Re-enter your password" required
                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                      <p id="passwordMatch" class="text-xs mt-2 hidden"></p>
                    </div>

                    <!-- Terms Checkbox -->
                    <label class="flex items-start gap-2 text-sm text-gray-400">
                      <input id="terms" type="checkbox" required class="mt-1 accent-[var(--primary-accent)]" />
                      I agree to the Terms of Service and Privacy Policy.
                    </label>

                    <!-- Submit Button -->
                    <button type="submit"
                      class="w-full py-3 rounded-lg bg-[var(--primary-accent)] text-black font-semibold hover:opacity-90 transition">
                      Create Account
                    </button>

                    <!-- Link to Login -->
                    <p class="text-sm text-gray-400 text-center">
                      Already have an account?
                      <a href="<%= routes.loginRoute %>" class="text-white hover:underline">Sign in</a>
                    </p>
                  </form>

        </section>
      </div>
    </main>


    <script src="/js/signup.js"></script>
</body>

</html>