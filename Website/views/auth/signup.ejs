<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %> 

<body class="bg-brand-slate text-white min-h-screen flex flex-col">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-10">
            
            <section class="flex flex-col justify-center text-left">
                <span class="text-sm uppercase tracking-widest text-brand-indigo font-black mb-2 font-display">
                 Get started
                </span>
                <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mt-3 font-display uppercase tracking-tighter leading-none">
                    Create your <br> <span class="text-brand-amber">account</span>
                </h1>
                <p class="text-slate-400 mt-6 text-base sm:text-lg font-sans italic border-l-4 border-brand-indigo pl-6">
                    Join the incubator platform to track milestones, access resources, and connect with technical wizards.
                </p>
            </section>

            <section class="bg-white border-4 border-black p-6 sm:p-10 shadow-neo text-black relative">
                
                <div id="errorMessage" class="hidden bg-red-100 border-4 border-red-600 p-4 mb-6 flex items-start gap-3">
                    <div class="flex-1 text-red-800 font-bold text-sm uppercase font-display">
                        Error: <span id="errorText" class="font-sans italic"></span>
                    </div>
                </div>

                <% if (typeof success !=='undefined' && success) { %>
                    <div class="bg-green-100 border-4 border-green-600 p-4 mb-6 flex items-start gap-3">
                        <div class="flex-1 text-green-800 font-bold text-sm uppercase font-display">
                            Success: <span class="font-sans italic"><%= success %></span>
                        </div>
                    </div>
                <% } %>

                <form id="signupForm" action="/v1/auth/register" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-xs font-black uppercase mb-2 font-display tracking-widest text-slate-500" for="name">Full name</label>
                        <input id="name" name="name" type="text" placeholder="YOUR NAME" required
                            class="w-full px-4 py-4 border-4 border-black bg-slate-50 text-black focus:outline-none focus:bg-white transition-all font-bold placeholder-slate-300" />
                    </div>

                    <div>
                        <label class="block text-xs font-black uppercase mb-2 font-display tracking-widest text-slate-500" for="email">Email address</label>
                        <input id="email" name="email" type="email" placeholder="YOU@EXAMPLE.COM" required
                            class="w-full px-4 py-4 border-4 border-black bg-slate-50 text-black focus:outline-none focus:bg-white transition-all font-bold placeholder-slate-300" />
                    </div>

                    <div>
                        <label class="block text-xs font-black uppercase mb-2 font-display tracking-widest text-slate-500" for="password">Password</label>
                        <input id="password" name="password" type="password" placeholder="********" required
                            class="w-full px-4 py-4 border-4 border-black bg-slate-50 text-black focus:outline-none focus:bg-white transition-all font-bold" />
                    </div>

                    <div>
                        <label class="block text-xs font-black uppercase mb-2 font-display tracking-widest text-slate-500" for="confirmPassword">Confirm Password</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" placeholder="********" required
                            class="w-full px-4 py-4 border-4 border-black bg-slate-50 text-black focus:outline-none focus:bg-white transition-all font-bold" />
                        <p id="passwordMatch" class="text-xs mt-2 hidden font-black italic uppercase"></p>
                    </div>

                    <label class="flex items-start gap-3 text-sm font-bold cursor-pointer group">
                        <input id="terms" type="checkbox" required class="mt-1 w-5 h-5 border-4 border-black accent-brand-indigo cursor-pointer" />
                        <span class="text-slate-600 group-hover:text-black transition-colors">I agree to the Terms of Service and Privacy Policy.</span>
                    </label>

                    <button type="submit"
                        class="w-full py-4 border-4 border-black bg-brand-indigo text-white font-black text-xl shadow-neo hover:translate-y-1 hover:shadow-none transition-all font-display tracking-widest uppercase">
                        Create Account
                    </button>

                    <p class="text-sm font-bold text-slate-500 text-center uppercase tracking-tight">
                        Already have an account?
                        <a href="<%= routes.loginRoute %>" class="text-brand-indigo underline hover:bg-brand-indigo hover:text-white px-1 transition-all">Sign in</a>
                    </p>
                </form>
            </section>
        </div>
    </main>

    <script src="/js/signup.js"></script>
</body>
</html>