<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile | Incubator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Space Grotesk', sans-serif; background-color: #FFFDF5; }
        .neo-brutalism-card {
            background-color: white;
            border: 4px solid black;
            box-shadow: 6px 6px 0px 0px #000;
        }
        .neo-brutalism-input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid black;
            background-color: #FFFDF5;
            font-weight: bold;
            outline: none;
            transition: all 0.2s;
        }
        .neo-brutalism-input:focus {
            background-color: white;
            box-shadow: 4px 4px 0px 0px #000;
            transform: translate(-2px, -2px);
        }
        .neo-brutalism-btn {
            background-color: black;
            color: white;
            padding: 12px 24px;
            font-weight: 900;
            text-transform: uppercase;
            border: 2px solid black;
            box-shadow: 4px 4px 0px 0px #4f46e5;
            transition: all 0.2s;
        }
        .neo-brutalism-btn:hover {
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0px 0px #4f46e5;
        }
    </style>
</head>

<body class="text-black min-h-screen flex flex-col">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 px-6 py-10">
        <div class="max-w-7xl mx-auto">
            
            <div class="mb-10">
                <span class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-2 inline-block transform -rotate-1">
                    User Settings
                </span>
                <h1 class="text-5xl md:text-6xl font-black text-black mb-2 uppercase tracking-tighter">
                    Your <span class="bg-[#4f46e5] text-white px-2 border-4 border-black shadow-[4px_4px_0px_0px_#000] italic inline-block transform rotate-1">Profile</span>
                </h1>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

                <aside class="lg:col-span-3">
                    <div class="neo-brutalism-card p-6 sticky top-6">
                        <nav class="space-y-4">
                            <a href="#profile-info"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black bg-[#4f46e5] text-white font-black uppercase shadow-[3px_3px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_#000] transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <span>Profile Info</span>
                            </a>
                            <a href="<%= routes.funding %>/new"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black bg-white text-black font-black uppercase hover:bg-gray-50 shadow-[3px_3px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_#000] transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>Request Funding</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                <div class="lg:col-span-9 space-y-8">

                    <% if (error) { %>
                        <div class="bg-red-100 border-4 border-red-500 p-4 flex items-center gap-4 shadow-[4px_4px_0_0_#ef4444]">
                            <svg class="w-8 h-8 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <div>
                                <h3 class="text-red-700 font-black uppercase text-lg">Error</h3>
                                <p class="text-red-600 font-bold"><%= error %></p>
                            </div>
                        </div>
                    <% } %>

                    <% if (success) { %>
                        <div class="bg-green-100 border-4 border-green-500 p-4 flex items-center gap-4 shadow-[4px_4px_0_0_#22c55e]">
                            <svg class="w-8 h-8 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <div>
                                <h3 class="text-green-700 font-black uppercase text-lg">Success</h3>
                                <p class="text-green-600 font-bold"><%= success %></p>
                            </div>
                        </div>
                    <% } %>

                    <section id="profile-picture" class="neo-brutalism-card p-8">
                        <div class="flex items-center gap-3 mb-6 border-b-4 border-black pb-2 w-fit">
                            <span class="bg-[#f59e0b] p-2 border-2 border-black text-black">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </span>
                            <h2 class="text-2xl font-black uppercase tracking-tight">Avatar Settings</h2>
                        </div>

                        <div class="flex flex-col sm:flex-row items-center gap-8">
                            <div class="relative group">
                                <% if (user && user.profilePicture) { %>
                                    <img src="<%= user.profilePicture %>?v=<%= Date.now() %>" alt="Profile"
                                        class="w-40 h-40 object-cover border-4 border-black shadow-[4px_4px_0_0_#000]">
                                <% } else { %>
                                    <div class="w-40 h-40 bg-[#f59e0b] border-4 border-black flex items-center justify-center shadow-[4px_4px_0_0_#000]">
                                        <span class="text-6xl font-black text-black">
                                            <%= user && user.name ? user.name.charAt(0).toUpperCase() : '?' %>
                                        </span>
                                    </div>
                                <% } %>
                                <div class="absolute -bottom-2 -right-2 bg-black text-white px-2 py-1 text-xs font-bold border-2 border-white">
                                    EDIT
                                </div>
                            </div>

                            <div class="flex-1 w-full">
                                <form action="/v1/auth/profile/upload-picture" method="POST" enctype="multipart/form-data" class="space-y-4">
                                    <div>
                                        <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500" for="profilePicture">
                                            Upload New Picture
                                        </label>
                                        <input id="profilePicture" name="profilePicture" type="file" accept="image/*" required
                                            class="w-full px-4 py-3 border-2 border-black bg-white font-bold cursor-pointer file:mr-4 file:py-2 file:px-4 file:border-2 file:border-black file:bg-[#f59e0b] file:text-black file:font-black file:uppercase hover:file:bg-black hover:file:text-[#f59e0b] transition-all" />
                                        <p class="text-xs font-bold text-gray-400 mt-2 uppercase">Max size: 5MB (JPG, PNG)</p>
                                    </div>
                                    <button type="submit" class="neo-brutalism-btn w-full sm:w-auto">
                                        Update Avatar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </section>

                    <section id="profile-info" class="neo-brutalism-card p-8">
                        <div class="flex items-center gap-3 mb-6 border-b-4 border-black pb-2 w-fit">
                            <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
                                </svg>
                            </span>
                            <h2 class="text-2xl font-black uppercase tracking-tight">Identity Data</h2>
                        </div>

                        <div class="space-y-6">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500" for="name">
                                        Full Name
                                    </label>
                                    <div class="flex border-2 border-black bg-gray-100 opacity-70">
                                        <div class="w-12 bg-black flex items-center justify-center text-white border-r-2 border-black">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                            </svg>
                                        </div>
                                        <input id="name" type="text" value="<%= user ? user.name : '' %>" readonly
                                            class="w-full px-4 py-3 bg-transparent font-bold uppercase text-gray-600 outline-none cursor-not-allowed" />
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500" for="email">
                                        Email Address
                                    </label>
                                    <div class="flex border-2 border-black bg-gray-100 opacity-70">
                                        <div class="w-12 bg-black flex items-center justify-center text-white border-r-2 border-black">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                        <input id="email" type="email" value="<%= user ? user.email : '' %>" readonly
                                            class="w-full px-4 py-3 bg-transparent font-bold lowercase text-gray-600 outline-none cursor-not-allowed" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section id="change-password" class="neo-brutalism-card p-8">
                        <div class="flex items-center gap-3 mb-6 border-b-4 border-black pb-2 w-fit">
                            <span class="bg-[#0f172a] p-2 border-2 border-black text-white">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </span>
                            <h2 class="text-2xl font-black uppercase tracking-tight">Security Access</h2>
                        </div>

                        <form action="/v1/auth/profile/update-password" method="POST" class="space-y-6">
                            <div>
                                <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500" for="currentPassword">
                                    Current Password
                                </label>
                                <input id="currentPassword" name="currentPassword" type="password" required
                                    class="neo-brutalism-input" placeholder="••••••••" />
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500" for="newPassword">
                                        New Password
                                    </label>
                                    <input id="newPassword" name="newPassword" type="password" required
                                        class="neo-brutalism-input" placeholder="••••••••" />
                                    <p class="text-[10px] font-bold text-gray-400 mt-1 uppercase">Min 8 chars required</p>
                                </div>

                                <div>
                                    <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500" for="confirmPassword">
                                        Confirm New Password
                                    </label>
                                    <input id="confirmPassword" name="confirmPassword" type="password" required
                                        class="neo-brutalism-input" placeholder="••••••••" />
                                </div>
                            </div>

                            <div class="pt-4 border-t-2 border-black/10">
                                <button type="submit" class="neo-brutalism-btn w-full sm:w-auto flex items-center justify-center gap-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                                    </svg>
                                    Update Credentials
                                </button>
                            </div>
                        </form>
                    </section>

                </div>
            </div>
        </div>
    </main>
</body>
</html>