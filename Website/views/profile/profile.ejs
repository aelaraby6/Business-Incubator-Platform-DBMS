<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile</title>
    <link href="/css/style.css" rel="stylesheet" />
</head>

<body class="bg-black text-white min-h-screen flex flex-col">
    <%- include('../partials/header.ejs') %>

        <main class="flex-1 px-4 py-8">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

                    <!-- Sidebar -->
                    <aside class="lg:col-span-3">
                        <div class="bg-neutral-900/70 border border-gray-800 rounded-2xl p-6 sticky top-6">
                            <nav class="space-y-2">
                                <a href="#profile-info"
                                    class="flex items-center gap-3 px-4 py-3 rounded-lg bg-[var(--primary-accent)]/10 text-[var(--primary-accent)] border border-[var(--primary-accent)]/20">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                    </svg>
                                    <span class="font-medium">Profile Info</span>
                                </a>
                                <a href="<%= routes.funding %>/new"
                                    class="flex items-center gap-3 px-4 py-3 rounded-lg bg-[var(--primary-accent)]/10 text-[var(--primary-accent)] border border-[var(--primary-accent)]/20">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                    </svg>
                                    <span class="font-medium">Request Funding</span>
                                </a>
                            </nav>
                        </div>
                    </aside>

                    <!-- Main Content -->
                    <div class="lg:col-span-9 space-y-6">

                        <!-- Error/Success Messages -->
                        <% if (error) { %>
                            <div class="bg-red-900/20 border border-red-500 rounded-2xl p-4 flex items-start gap-3">
                                <svg class="w-6 h-6 text-red-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <div class="flex-1">
                                    <h3 class="text-red-500 font-semibold mb-1">Error</h3>
                                    <p class="text-red-300 text-sm">
                                        <%= error %>
                                    </p>
                                </div>
                            </div>
                            <% } %>

                                <% if (success) { %>
                                    <div
                                        class="bg-green-900/20 border border-green-500 rounded-2xl p-4 flex items-start gap-3">
                                        <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="none"
                                            stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        <div class="flex-1">
                                            <h3 class="text-green-500 font-semibold mb-1">Success</h3>
                                            <p class="text-green-300 text-sm">
                                                <%= success %>
                                            </p>
                                        </div>
                                    </div>
                                    <% } %>

                                        <!-- Profile Picture Section -->
                                        <section id="profile-picture"
                                            class="bg-neutral-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8">
                                            <h2 class="text-2xl font-bold mb-6">Profile Picture</h2>

                                            <div class="flex flex-col sm:flex-row items-center gap-6">
                                                <div class="relative">
                                                    <% if (user && user.profilePicture) { %>
                                                        <img src="<%= user.profilePicture %>?v=<%= Date.now() %>"
                                                            alt="Profile"
                                                            class="w-32 h-32 rounded-full object-cover border-4 border-gray-700">
                                                        <% } else { %>
                                                            <div
                                                                class="w-32 h-32 rounded-full bg-gray-800 border-4 border-gray-700 flex items-center justify-center">
                                                                <svg class="w-16 h-16 text-gray-600" fill="none"
                                                                    stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                        stroke-width="2"
                                                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                                                </svg>
                                                            </div>
                                                            <% } %>
                                                </div>

                                                <div class="flex-1 w-full">
                                                    <form action="/v1/auth/profile/upload-picture" method="POST"
                                                        enctype="multipart/form-data" class="space-y-4">
                                                        <div>
                                                            <label class="block text-sm text-gray-300 mb-2"
                                                                for="profilePicture">
                                                                Upload new picture
                                                            </label>
                                                            <input id="profilePicture" name="profilePicture" type="file"
                                                                accept="image/*" required
                                                                class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-[var(--primary-accent)] file:text-black file:font-semibold hover:file:opacity-90 focus:outline-none focus:border-[var(--primary-accent)]" />
                                                            <p class="text-xs text-gray-500 mt-2">PNG, JPG or JPEG (Max.
                                                                5MB)</p>
                                                        </div>

                                                        <button type="submit"
                                                            class="px-6 py-3 rounded-lg bg-[var(--primary-accent)] text-black font-semibold hover:opacity-90 transition">
                                                            Upload Picture
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </section>

                                        <!-- Profile Info Section -->
                                        <section id="profile-info"
                                            class="bg-neutral-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8">
                                            <h2 class="text-2xl font-bold mb-6">Personal Information</h2>

                                            <div class="space-y-5">
                                                <!-- Full Name -->
                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                                    <div>
                                                        <label class="block text-sm text-gray-300 mb-2" for="name">Full
                                                            Name</label>
                                                        <input id="name" name="name" type="text"
                                                            value="<%= user ? user.name : '' %>" placeholder="Your name"
                                                            readonly
                                                            class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none cursor-not-allowed opacity-70" />
                                                        <p class="text-xs text-gray-500 mt-1">Name cannot be changed</p>
                                                    </div>

                                                    <!-- Email -->
                                                    <div>
                                                        <label class="block text-sm text-gray-300 mb-2"
                                                            for="email">Email</label>
                                                        <input id="email" name="email" type="email"
                                                            value="<%= user ? user.email : '' %>"
                                                            placeholder="you@example.com" readonly
                                                            class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none cursor-not-allowed opacity-70" />
                                                        <p class="text-xs text-gray-500 mt-1">Email cannot be changed
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <!-- Change Password Section -->
                                        <section id="change-password"
                                            class="bg-neutral-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8">
                                            <h2 class="text-2xl font-bold mb-6">Change Password</h2>

                                            <form action="/v1/auth/profile/update-password" method="POST"
                                                class="space-y-5">
                                                <!-- Current Password -->
                                                <div>
                                                    <label class="block text-sm text-gray-300 mb-2"
                                                        for="currentPassword">
                                                        Current Password
                                                    </label>
                                                    <input id="currentPassword" name="currentPassword" type="password"
                                                        placeholder="Enter your current password" required
                                                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                                                </div>

                                                <!-- New Password -->
                                                <div>
                                                    <label class="block text-sm text-gray-300 mb-2" for="newPassword">
                                                        New Password
                                                    </label>
                                                    <input id="newPassword" name="newPassword" type="password"
                                                        placeholder="Enter new password" required
                                                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                                                    <p class="text-xs text-gray-500 mt-2">Password must be at least 8
                                                        characters</p>
                                                </div>

                                                <!-- Confirm New Password -->
                                                <div>
                                                    <label class="block text-sm text-gray-300 mb-2"
                                                        for="confirmPassword">
                                                        Confirm New Password
                                                    </label>
                                                    <input id="confirmPassword" name="confirmPassword" type="password"
                                                        placeholder="Confirm new password" required
                                                        class="w-full px-4 py-3 rounded-lg bg-black border border-gray-700 text-white focus:outline-none focus:border-[var(--primary-accent)]" />
                                                </div>

                                                <!-- Submit Button -->
                                                <button type="submit"
                                                    class="w-full sm:w-auto px-8 py-3 rounded-lg bg-[var(--primary-accent)] text-black font-semibold hover:opacity-90 transition">
                                                    Update Password
                                                </button>
                                            </form>
                                        </section>

                    </div>
                </div>
            </div>
        </main>

</body>

</html>