<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head.ejs') %>

<body class="bg-[#FFFDF5] text-black min-h-screen flex flex-col font-sans">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 px-6 py-10">
        <div class="max-w-7xl mx-auto">
            
            <div class="mb-10">
                <span class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-2 inline-block transform -rotate-1">
                    User Settings
                </span>
                <h1 class="text-5xl md:text-6xl font-black text-black mb-2 uppercase tracking-tighter">
                    Your <span class="bg-[#4f46e5] text-white px-2 border-4 border-black shadow-[4px_4px_0px_0px_#000] italic inline-block transform rotate-1">Profile</span>
                </h1>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

                <aside class="lg:col-span-3">
                    <div class="bg-white border-4 border-black p-6 sticky top-6 shadow-[6px_6px_0px_0px_#000]">
                        <nav class="space-y-4">
                            <a href="#profile-info"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black bg-[#4f46e5] text-white font-black uppercase shadow-[3px_3px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_#000] transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <span>Profile Info</span>
                            </a>
                            <a href="<%= routes.funding %>/new"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black bg-white text-black font-black uppercase hover:bg-gray-50 shadow-[3px_3px_0px_0px_#000] hover:-translate-y-1 hover:shadow-[5px_5px_0px_0px_#000] transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span>Request Funding</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                <div class="lg:col-span-9 space-y-8">

                    <% if (error) { %>
                        <div class="bg-red-100 border-4 border-red-500 p-4 flex items-center gap-4 shadow-[4px_4px_0_0_#ef4444]">
                            <div class="flex-shrink-0">⚠️</div>
                            <div>
                                <h3 class="text-red-700 font-black uppercase text-lg">Error</h3>
                                <p class="text-red-600 font-bold"><%= error %></p>
                            </div>
                        </div>
                    <% } %>

                    <% if (success) { %>
                        <div class="bg-green-100 border-4 border-green-500 p-4 flex items-center gap-4 shadow-[4px_4px_0_0_#22c55e]">
                            <div class="flex-shrink-0">✅</div>
                            <div>
                                <h3 class="text-green-700 font-black uppercase text-lg">Success</h3>
                                <p class="text-green-600 font-bold"><%= success %></p>
                            </div>
                        </div>
                    <% } %>

                    <section id="profile-picture" class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000]">
                        <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-2 w-fit">
                            <span class="bg-[#f59e0b] p-2 border-2 border-black text-black">📸</span>
                            <h2 class="text-2xl font-black uppercase tracking-tight">Avatar Settings</h2>
                        </div>

                        <div class="flex flex-col sm:flex-row items-center gap-8">
                            <div class="relative">
                                <% if (user && user.profilePicture) { %>
                                    <img src="<%= user.profilePicture %>?v=<%= Date.now() %>" alt="Profile"
                                        class="w-40 h-40 object-cover border-4 border-black shadow-[4px_4px_0_0_#000]">
                                <% } else { %>
                                    <div class="w-40 h-40 bg-[#f59e0b] border-4 border-black flex items-center justify-center shadow-[4px_4px_0_0_#000]">
                                        <span class="text-6xl font-black text-black"><%= user && user.name ? user.name.charAt(0).toUpperCase() : '?' %></span>
                                    </div>
                                <% } %>
                            </div>

                            <div class="flex-1 w-full">
                                <form action="/v1/auth/profile/upload-picture" method="POST" enctype="multipart/form-data" class="space-y-4">
                                    <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500">New Picture</label>
                                    <input name="profilePicture" type="file" accept="image/*" required
                                        class="w-full p-2 border-2 border-black bg-[#FFFDF5] font-bold file:mr-4 file:py-2 file:px-4 file:border-2 file:border-black file:bg-[#f59e0b] file:text-black file:font-black file:uppercase hover:file:bg-black hover:file:text-white transition-all" />
                                    
                                    <button type="submit" class="bg-black text-white px-6 py-3 font-black uppercase border-2 border-black shadow-[4px_4px_0_0_#4f46e5] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
                                        Update Avatar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </section>

                    <section id="profile-info" class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000]">
                        <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-2 w-fit">
                            <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">🆔</span>
                            <h2 class="text-2xl font-black uppercase tracking-tight">Identity Data</h2>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Full Name</label>
                                <input type="text" value="<%= user ? user.name : '' %>" readonly
                                    class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-bold uppercase text-gray-500 cursor-not-allowed" />
                            </div>
                            <div class="space-y-2">
                                <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Email Address</label>
                                <input type="email" value="<%= user ? user.email : '' %>" readonly
                                    class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-bold text-gray-500 cursor-not-allowed" />
                            </div>
                        </div>
                    </section>

                    <section id="change-password" class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000]">
                        <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-2 w-fit">
                            <span class="bg-[#0f172a] p-2 border-2 border-black text-white">🔐</span>
                            <h2 class="text-2xl font-black uppercase tracking-tight">Security Access</h2>
                        </div>

                        <form action="/v1/auth/profile/update-password" method="POST" class="space-y-6">
                            <div class="space-y-2">
                                <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Current Password</label>
                                <input name="currentPassword" type="password" required placeholder="••••••••"
                                    class="w-full px-4 py-3 border-2 border-black bg-[#FFFDF5] font-bold focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#000] transition-all" />
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="block text-xs font-black uppercase tracking-widest text-gray-500">New Password</label>
                                    <input name="newPassword" type="password" required placeholder="••••••••"
                                        class="w-full px-4 py-3 border-2 border-black bg-[#FFFDF5] font-bold focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#000] transition-all" />
                                </div>
                                <div class="space-y-2">
                                    <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Confirm New</label>
                                    <input name="confirmPassword" type="password" required placeholder="••••••••"
                                        class="w-full px-4 py-3 border-2 border-black bg-[#FFFDF5] font-bold focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#000] transition-all" />
                                </div>
                            </div>

                            <button type="submit" class="bg-black text-white px-10 py-4 font-black uppercase border-2 border-black shadow-[4px_4px_0_0_#f59e0b] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
                                Update Credentials
                            </button>
                        </form>
                    </section>

                </div>
            </div>
        </div>
    </main>
</body>
</html>